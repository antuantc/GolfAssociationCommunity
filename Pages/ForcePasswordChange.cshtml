@page
@model GolfAssociationCommunity.Pages.ForcePasswordChangeModel
@{
    ViewData["Title"] = "Change Password";
}

<section class="section-panel">
    <h1>Change Password Required</h1>
    <p>An administrator requires you to change your password before continuing.</p>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="message error"></div>

        <div class="card-grid">
            <div>
                <label asp-for="Input.NewPassword"></label>
                <input asp-for="Input.NewPassword" class="form-control" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
        </div>

        <button type="submit" class="btn">Update Password</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
