@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Golf Association Community</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @{ 
        var publicAssociationId = ViewData["PublicAssociationId"] as int?;
        if (publicAssociationId is null && ViewData["PublicAssociationId"] != null)
        {
            publicAssociationId = Convert.ToInt32(ViewData["PublicAssociationId"]);
        }
        var publicAssociationName = ViewData["PublicAssociationName"]?.ToString();
    }
    <header class="site-header">
        <div class="container">
            @if (publicAssociationId.HasValue && !string.IsNullOrWhiteSpace(publicAssociationName))
            {
                <a class="brand" href="~/Associations/Details/@publicAssociationId">@publicAssociationName</a>
            }
            else
            {
                <a class="brand" href="~/">Golf Association Community</a>
            }
            <nav class="site-nav">
                @if (publicAssociationId.HasValue)
                {
                    <a href="~/Associations/Details/@publicAssociationId">Association Home</a>
                    <a href="~/Associations/Tournaments?associationId=@publicAssociationId">Tournaments</a>
                    <a href="~/">All Associations</a>
                }
                else
                {
                    <a href="~/">Home</a>
                    <a href="~/">Associations</a>
                }
                @if (SignInManager.IsSignedIn(User))
                {
                    @if (User.IsInRole("AssociationAdmin"))
                    {
                        <a href="~/AssociationAdmin">Association Portal</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="~/Admin">Admin Dashboard</a>
                    }
                    <a href="~/Identity/Account/Manage">My Account</a>
                    <form method="post" action="~/Identity/Account/Logout" class="inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="link-button">Logout</button>
                    </form>
                }
                else
                {
                    <a href="~/Identity/Account/Login">Admin Login</a>
                }
            </nav>
        </div>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="container">
            <p>Golf Association Community &copy; @DateTime.UtcNow.Year</p>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
