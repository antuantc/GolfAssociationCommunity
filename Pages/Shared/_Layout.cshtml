@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Golf Association Community</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a class="brand" href="~/">Golf Association Community</a>
            <nav class="site-nav">
                <a href="~/">Home</a>
                <a href="~/Associations">Associations</a>
                <a href="~/Tournaments">Tournaments</a>
                <a href="~/swagger">API Docs</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a href="~/MyRegistrations">My Registrations</a>
                    <a href="~/Identity/Account/Manage">My Account</a>
                    <form method="post" action="~/Identity/Account/Logout" class="inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="link-button">Logout</button>
                    </form>
                }
                else
                {
                    <a href="~/Identity/Account/Login">Login</a>
                    <a href="~/Identity/Account/Register">Register</a>
                }
            </nav>
        </div>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="container">
            <p>Golf Association Community &copy; @DateTime.UtcNow.Year</p>
        </div>
    </footer>
</body>
</html>
