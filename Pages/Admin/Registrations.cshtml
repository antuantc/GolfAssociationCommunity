@page
@using GolfAssociationCommunity.Models
@model GolfAssociationCommunity.Pages.Admin.RegistrationsModel
@{
    ViewData["Title"] = "Manage Registrations";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Registrations</h1>
            <p>Manage tournament registrations, confirm payments, and withdraw players across the platform.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    <form method="get" class="admin-filter-bar">
        <div>
            <label for="search">Search</label>
            <input id="search" name="Search" value="@Model.Search" class="form-control" placeholder="Player, tournament, or association" />
        </div>
        <div>
            <label for="statusFilter">Status</label>
            <select id="statusFilter" name="StatusFilter" class="form-control">
                <option value="">All statuses</option>
                @foreach (var status in Enum.GetValues<RegistrationStatus>())
                {
                    <option value="@status" selected="@(Model.StatusFilter == status)">@status</option>
                }
            </select>
        </div>
        <div>
            <label for="paymentFilter">Payment</label>
            <select id="paymentFilter" name="PaymentFilter" class="form-control">
                <option value="">All payments</option>
                <option value="Confirmed" selected="@(Model.PaymentFilter == "Confirmed")">Confirmed</option>
                <option value="Pending" selected="@(Model.PaymentFilter == "Pending")">Pending</option>
            </select>
        </div>
        <div class="admin-filter-bar__actions">
            <button type="submit" class="btn btn-sm">Apply Filters</button>
            <a class="btn btn-secondary btn-sm" href="~/Admin/Registrations">Reset</a>
        </div>
    </form>

    @if (Model.Registrations.Count == 0)
    {
        <p>No registrations found matching the current filters.</p>
    }
    else
    {
        <form id="bulk-reg-delete" method="post" asp-page-handler="DeleteSelected">
            <input type="hidden" name="Search" value="@Model.Search" />
            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
            <input type="hidden" name="PaymentFilter" value="@Model.PaymentFilter" />
            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
        </form>
        <div class="table-toolbar">
            <label class="table-toolbar__select-all">
                <input type="checkbox" id="select-all-regs" /> Select all on this page
            </label>
        </div>
        <div class="table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th><span class="sr-only">Select</span></th>
                    <th>Actions</th>
                    <th>Player</th>
                    <th>Tournament</th>
                    <th>Association</th>
                    <th>Registered On</th>
                    <th>Status</th>
                    <th>Handicap</th>
                    <th>Payment</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var registration in Model.Registrations)
            {
                <tr>
                    <td><input type="checkbox" class="reg-check" name="Ids" value="@registration.Id" form="bulk-reg-delete" /></td>
                    <td>
                        <form method="post" asp-page-handler="SetStatus" asp-route-id="@registration.Id" class="inline-form">
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                            <input type="hidden" name="PaymentFilter" value="@Model.PaymentFilter" />
                            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                            <select name="status" class="form-control" aria-label="Change registration status" style="display:inline-block;width:auto;font-size:0.85rem;padding:0.3rem 0.5rem;">
                                @foreach (var status in Enum.GetValues<RegistrationStatus>())
                                {
                                    <option value="@status" selected="@(status == registration.Status)">@status</option>
                                }
                            </select>
                            <button type="submit" class="link-button" title="Save the selected status">Update Status</button>
                        </form>
                        @if (!registration.PaymentConfirmed)
                        {
                            <form method="post" asp-page-handler="ConfirmPayment" asp-route-id="@registration.Id" class="inline-form">
                                <input type="hidden" name="Search" value="@Model.Search" />
                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                <input type="hidden" name="PaymentFilter" value="@Model.PaymentFilter" />
                                <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                                <button type="submit" class="link-button" title="Mark payment as confirmed">Confirm Payment</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="Withdraw" asp-route-id="@registration.Id" class="inline-form">
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                            <input type="hidden" name="PaymentFilter" value="@Model.PaymentFilter" />
                            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                            <button type="submit" class="link-button" title="Withdraw this player from the tournament">Withdraw</button>
                        </form>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@registration.Id" class="inline-form"
                              onsubmit="return confirm('Permanently delete this registration? This cannot be undone.')">
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                            <input type="hidden" name="PaymentFilter" value="@Model.PaymentFilter" />
                            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                            <button type="submit" class="link-button danger" title="Permanently delete this registration">Delete</button>
                        </form>
                    </td>
                    <td>@registration.PlayerEmail</td>
                    <td><strong>@registration.TournamentName</strong></td>
                    <td>@registration.AssociationName</td>
                    <td>@registration.RegistrationDate.ToString("MMM d, yyyy")</td>
                    <td>
                        @{
                            var regBadgeClass = registration.Status switch {
                                RegistrationStatus.Registered => "status-badge--green",
                                RegistrationStatus.Pending    => "status-badge--yellow",
                                RegistrationStatus.Cancelled  => "status-badge--red",
                                RegistrationStatus.Withdrew   => "status-badge--gray",
                                _                             => "status-badge--gray"
                            };
                        }
                        <span class="status-badge @regBadgeClass">@registration.Status</span>
                    </td>
                    <td>@(registration.Handicap.HasValue ? registration.Handicap.Value.ToString("0.0#") : "—")</td>
                    <td>
                        @if (registration.PaymentConfirmed)
                        {
                            <span class="status-badge status-badge--green">Confirmed</span>
                            @if (!string.IsNullOrWhiteSpace(registration.CardLast4))
                            {
                                <small class="text-muted"> **** @registration.CardLast4</small>
                            }
                        }
                        else
                        {
                            <span class="status-badge status-badge--yellow">Pending</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>

        <div class="form-actions" style="margin-top:0.75rem;">
            <button type="submit" form="bulk-reg-delete" class="btn btn-danger"
                    onclick="return document.querySelectorAll('.reg-check:checked').length > 0 || (alert('Select at least one registration first.'), false)">
                Delete Selected
            </button>
        </div>

        <div class="admin-pagination">
            <span>Page @Model.PageNumber of @Model.TotalPages</span>
            @if (Model.PageNumber > 1)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Registrations" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-PaymentFilter="@Model.PaymentFilter" asp-route-CurrentPage="@(Model.PageNumber - 1)">&#8592; Previous</a>
            }
            @if (Model.PageNumber < Model.TotalPages)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Registrations" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-PaymentFilter="@Model.PaymentFilter" asp-route-CurrentPage="@(Model.PageNumber + 1)">Next &#8594;</a>
            }
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
    </div>
</section>
<script>
    document.getElementById('select-all-regs')?.addEventListener('change', function () {
        document.querySelectorAll('.reg-check').forEach(cb => cb.checked = this.checked);
    });
    document.querySelectorAll('.reg-check').forEach(function (cb) {
        cb.addEventListener('change', function () {
            var all = document.getElementById('select-all-regs');
            if (!all) return;
            var checks = document.querySelectorAll('.reg-check');
            var checked = document.querySelectorAll('.reg-check:checked');
            all.indeterminate = checked.length > 0 && checked.length < checks.length;
            all.checked = checks.length > 0 && checked.length === checks.length;
        });
    });
</script>
