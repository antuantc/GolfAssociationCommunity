@page
@model GolfAssociationCommunity.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Users</h1>
            @if (Model.CanManageRolesAndLockout)
            {
                <p>Manage roles, lockout status, and accounts across all associations.</p>
            }
            else
            {
                <p>Manage user accounts within your association.</p>
            }
        </div>
        @if (Model.CanManageRolesAndLockout)
        {
            <div class="admin-page-header__actions">
                <a class="btn" href="~/Admin/CreateUser">+ Create User</a>
            </div>
        }
    </div>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    <form method="get" class="admin-filter-bar">
        <div>
            <label for="search">Search</label>
            <input id="search" name="Search" value="@Model.Search" class="form-control" placeholder="Email, name, or association" />
        </div>
        <div>
            <label for="roleFilter">Role</label>
            <select id="roleFilter" name="RoleFilter" class="form-control">
                <option value="">All roles</option>
                <option value="Admin" selected="@(Model.RoleFilter == "Admin")">Admin</option>
                <option value="AssociationAdmin" selected="@(Model.RoleFilter == "AssociationAdmin")">Association Admin</option>
                <option value="Member" selected="@(Model.RoleFilter == "Member")">Standard User</option>
            </select>
        </div>
        <div>
            <label for="statusFilter">Status</label>
            <select id="statusFilter" name="StatusFilter" class="form-control">
                <option value="">All statuses</option>
                <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                <option value="Locked" selected="@(Model.StatusFilter == "Locked")">Locked out</option>
            </select>
        </div>
        <div class="admin-filter-bar__actions">
            <button type="submit" class="btn btn-sm">Apply Filters</button>
            <a class="btn btn-secondary btn-sm" href="~/Admin/Users">Reset</a>
        </div>
    </form>

    @if (Model.Users.Count == 0)
    {
        <p>No users found matching the current filters.</p>
    }
    else
    {
        <div class="table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th>Actions</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Association</th>
                    <th>Role</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>
                        @if (Model.CanManageRolesAndLockout)
                        {
                            <a class="card-link" href="~/Admin/EditUser/@user.Id">Edit</a>
                            <form method="post" asp-page-handler="ToggleAdmin" asp-route-userId="@user.Id" class="inline-form">
                                <input type="hidden" name="Search" value="@Model.Search" />
                                <input type="hidden" name="RoleFilter" value="@Model.RoleFilter" />
                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                                <button type="submit" class="link-button" title="@(user.IsAdmin ? "Remove admin role from this user" : "Grant admin role to this user")">
                                    @(user.IsAdmin ? "Remove Admin" : "Make Admin")
                                </button>
                            </form>
                            @if (!user.IsAdmin)
                            {
                                <form method="post" asp-page-handler="ToggleAssociationAdmin" asp-route-userId="@user.Id" class="inline-form">
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <input type="hidden" name="RoleFilter" value="@Model.RoleFilter" />
                                    <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                    <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                                    @if (!user.IsAssociationAdmin)
                                    {
                                        <select name="associationId" class="form-control" aria-label="Select association for admin role" style="display:inline-block;width:auto;font-size:0.85rem;padding:0.3rem 0.5rem;">
                                            <option value="">Select association&hellip;</option>
                                            @foreach (var association in Model.Associations)
                                            {
                                                <option value="@association.Id">@association.Name</option>
                                            }
                                        </select>
                                    }
                                    <button type="submit" class="link-button" title="@(user.IsAssociationAdmin ? "Remove association admin role" : "Grant association admin role")">
                                        @(user.IsAssociationAdmin ? "Remove Assoc Admin" : "Make Assoc Admin")
                                    </button>
                                </form>
                            }
                            <form method="post" asp-page-handler="ToggleLockout" asp-route-userId="@user.Id" class="inline-form">
                                <input type="hidden" name="Search" value="@Model.Search" />
                                <input type="hidden" name="RoleFilter" value="@Model.RoleFilter" />
                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                                <button type="submit" class="link-button" title="@(user.IsLockedOut ? "Restore access for this user" : "Prevent this user from signing in")">
                                    @(user.IsLockedOut ? "Unlock Account" : "Lock Account")
                                </button>
                            </form>
                        }
                        <form method="post" asp-page-handler="DeleteUser" asp-route-userId="@user.Id" class="inline-form"
                              onsubmit="return confirm('Permanently delete @user.Email? This cannot be undone.');">
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="RoleFilter" value="@Model.RoleFilter" />
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                            <button type="submit" class="link-button danger" title="Permanently delete this user account">Delete</button>
                        </form>
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(user.DisplayName) ? "—" : user.DisplayName)</td>
                    <td>@user.Email</td>
                    <td>@(user.AssociationName ?? "—")</td>
                    <td>
                        @if (user.IsAdmin)
                        {
                            <span class="status-badge status-badge--blue">Admin</span>
                        }
                        else if (user.IsAssociationAdmin)
                        {
                            <span class="status-badge status-badge--yellow">Assoc. Admin</span>
                        }
                        else
                        {
                            <span class="status-badge status-badge--gray">Standard User</span>
                        }
                    </td>
                    <td>
                        @if (user.IsLockedOut)
                        {
                            <span class="status-badge status-badge--red">Locked</span>
                        }
                        else
                        {
                            <span class="status-badge status-badge--green">Active</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>

        <div class="admin-pagination">
            <span>Page @Model.PageNumber of @Model.TotalPages</span>
            @if (Model.PageNumber > 1)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Users" asp-route-Search="@Model.Search" asp-route-RoleFilter="@Model.RoleFilter" asp-route-StatusFilter="@Model.StatusFilter" asp-route-CurrentPage="@(Model.PageNumber - 1)">&#8592; Previous</a>
            }
            @if (Model.PageNumber < Model.TotalPages)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Users" asp-route-Search="@Model.Search" asp-route-RoleFilter="@Model.RoleFilter" asp-route-StatusFilter="@Model.StatusFilter" asp-route-CurrentPage="@(Model.PageNumber + 1)">Next &#8594;</a>
            }
        </div>
    }

    <div class="admin-back-nav">
        @if (Model.CanManageRolesAndLockout)
        {
            <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
        }
        else
        {
            <a class="btn btn-secondary" href="~/AssociationAdmin">&#8592; Back to Association Portal</a>
        }
    </div>
</section>
