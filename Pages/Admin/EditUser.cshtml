@page "{id}"
@model GolfAssociationCommunity.Pages.Admin.EditUserModel
@{
    ViewData["Title"] = "Edit User";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Edit User</h1>
            <p>Update the user's name, email address, or reset their password.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn btn-secondary btn-sm" href="~/Admin/Users">&#8592; Back to Users</a>
        </div>
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="message error"></div>

        <h2 class="form-section-title">Profile</h2>
        <div class="card-grid">
            <div>
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.FirstName"></label>
                <input asp-for="Input.FirstName" class="form-control" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.LastName"></label>
                <input asp-for="Input.LastName" class="form-control" />
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
        </div>

        <h2 class="form-section-title">Reset Password <small class="text-muted" style="font-size:0.8rem;font-weight:400;">(Optional — leave blank to keep current password)</small></h2>
        <div class="card-grid">
            <div>
                <label asp-for="Input.NewPassword"></label>
                <input asp-for="Input.NewPassword" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions" style="margin-top:1.5rem;">
            <button type="submit" class="btn">Save Changes</button>
            <a class="btn btn-secondary" href="~/Admin/Users">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
