@page
@using GolfAssociationCommunity.Models
@model GolfAssociationCommunity.Pages.Admin.TournamentsModel
@{
    ViewData["Title"] = "Manage Tournaments";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Tournaments</h1>
            <p>Review tournaments across all associations, change their status, or delete when needed.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    <form method="get" class="admin-filter-bar">
        <div>
            <label for="search">Search</label>
            <input id="search" name="Search" value="@Model.Search" class="form-control" placeholder="Tournament or association name" />
        </div>
        <div>
            <label for="statusFilter">Status</label>
            <select id="statusFilter" name="StatusFilter" class="form-control">
                <option value="">All statuses</option>
                @foreach (var status in Enum.GetValues<TournamentStatus>())
                {
                    <option value="@status" selected="@(Model.StatusFilter == status)">@status</option>
                }
            </select>
        </div>
        <div class="admin-filter-bar__actions">
            <button type="submit" class="btn btn-sm">Apply Filters</button>
            <a class="btn btn-secondary btn-sm" href="~/Admin/Tournaments">Reset</a>
        </div>
    </form>

    @if (Model.Tournaments.Count == 0)
    {
        <p>No tournaments found matching the current filters.</p>
    }
    else
    {
        <div class="table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th>Actions</th>
                    <th>Name</th>
                    <th>Association</th>
                    <th>Start Date</th>
                    <th>Status</th>
                    <th>Registered</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var tournament in Model.Tournaments)
            {
                <tr>
                    <td>
                        <form method="post" asp-page-handler="SetStatus" asp-route-id="@tournament.Id" class="inline-form">
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                            <select name="status" class="form-control" aria-label="Change tournament status" style="display:inline-block;width:auto;font-size:0.85rem;padding:0.3rem 0.5rem;">
                                @foreach (var status in Enum.GetValues<TournamentStatus>())
                                {
                                    <option value="@status" selected="@(status == tournament.Status)">@status</option>
                                }
                            </select>
                            <button type="submit" class="link-button" title="Save the selected status">Update Status</button>
                        </form>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@tournament.Id" class="inline-form"
                              onsubmit="return confirm('Permanently delete this tournament? This cannot be undone.');">
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                            <input type="hidden" name="CurrentPage" value="@Model.PageNumber" />
                            <button type="submit" class="link-button danger" title="Permanently delete this tournament">Delete</button>
                        </form>
                    </td>
                    <td><strong>@tournament.Name</strong></td>
                    <td>@tournament.AssociationName</td>
                    <td>@tournament.StartDate.ToString("MMM d, yyyy")</td>
                    <td>
                        @{
                            var badgeClass = tournament.Status switch {
                                TournamentStatus.Scheduled  => "status-badge--blue",
                                TournamentStatus.Ongoing    => "status-badge--green",
                                TournamentStatus.Completed  => "status-badge--gray",
                                TournamentStatus.Cancelled  => "status-badge--red",
                                _                           => "status-badge--yellow"
                            };
                        }
                        <span class="status-badge @badgeClass">@tournament.Status</span>
                    </td>
                    <td>@tournament.RegisteredCount</td>
                </tr>
            }
            </tbody>
        </table>
        </div>

        <div class="admin-pagination">
            <span>Page @Model.PageNumber of @Model.TotalPages</span>
            @if (Model.PageNumber > 1)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Tournaments" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-CurrentPage="@(Model.PageNumber - 1)">&#8592; Previous</a>
            }
            @if (Model.PageNumber < Model.TotalPages)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Tournaments" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-CurrentPage="@(Model.PageNumber + 1)">Next &#8594;</a>
            }
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
    </div>
</section>
