@page
@model GolfAssociationCommunity.Pages.Admin.AuditModel
@{
    ViewData["Title"] = "Audit Log";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Audit Log</h1>
            <p>Review all recorded admin actions. Filter by actor, action type, or date range.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn btn-secondary btn-sm"
               asp-page="/Admin/Audit" asp-page-handler="ExportCsv"
               asp-route-Search="@Model.Search"
               asp-route-ActorFilter="@Model.ActorFilter"
               asp-route-ActionFilter="@Model.ActionFilter"
               asp-route-DateFrom="@Model.DateFrom"
               asp-route-DateTo="@Model.DateTo"
               title="Download current results as a CSV file">&#8595; Export CSV</a>
        </div>
    </div>

    <form method="get" class="admin-filter-bar">
        <div>
            <label for="search">Search</label>
            <input id="search" name="Search" value="@Model.Search" class="form-control" placeholder="Action, actor, or details" />
        </div>
        <div>
            <label for="actorFilter">Actor (email)</label>
            <input id="actorFilter" name="ActorFilter" value="@Model.ActorFilter" class="form-control" placeholder="admin@example.com" />
        </div>
        <div>
            <label for="actionFilter">Action Type</label>
            <select id="actionFilter" name="ActionFilter" class="form-control">
                <option value="">All actions</option>
                @foreach (var action in Model.AvailableActions)
                {
                    <option value="@action" selected="@(string.Equals(Model.ActionFilter, action, StringComparison.OrdinalIgnoreCase))">@action</option>
                }
            </select>
        </div>
        <div>
            <label for="dateFrom">From</label>
            <input id="dateFrom" name="DateFrom" type="date" value="@Model.DateFrom" class="form-control" />
        </div>
        <div>
            <label for="dateTo">To</label>
            <input id="dateTo" name="DateTo" type="date" value="@Model.DateTo" class="form-control" />
        </div>
        <div class="admin-filter-bar__actions">
            <button type="submit" class="btn btn-sm">Apply Filters</button>
            <a class="btn btn-secondary btn-sm" href="~/Admin/Audit">Reset</a>
        </div>
    </form>

    @if (Model.Entries.Count == 0)
    {
        <p>No audit records found for the selected filters.</p>
    }
    else
    {
        <div class="table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Action</th>
                    <th>Actor</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var entry in Model.Entries)
            {
                <tr>
                    <td>@entry.AtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz")</td>
                    <td><span class="status-badge status-badge--blue">@entry.Action</span></td>
                    <td>@entry.Actor</td>
                    <td>@entry.Details</td>
                </tr>
            }
            </tbody>
        </table>
        </div>

        <div class="admin-pagination">
            <span>Page @Model.PageNumber of @Model.TotalPages</span>
            @if (Model.PageNumber > 1)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Audit" asp-route-Search="@Model.Search" asp-route-ActorFilter="@Model.ActorFilter" asp-route-ActionFilter="@Model.ActionFilter" asp-route-DateFrom="@Model.DateFrom" asp-route-DateTo="@Model.DateTo" asp-route-CurrentPage="@(Model.PageNumber - 1)">&#8592; Previous</a>
            }
            @if (Model.PageNumber < Model.TotalPages)
            {
                <a class="btn btn-secondary btn-sm" asp-page="/Admin/Audit" asp-route-Search="@Model.Search" asp-route-ActorFilter="@Model.ActorFilter" asp-route-ActionFilter="@Model.ActionFilter" asp-route-DateFrom="@Model.DateFrom" asp-route-DateTo="@Model.DateTo" asp-route-CurrentPage="@(Model.PageNumber + 1)">Next &#8594;</a>
            }
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
    </div>
</section>
