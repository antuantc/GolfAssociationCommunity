@page "{sourceType}/{id:int}"
@model GolfAssociationCommunity.Pages.Admin.Transactions.DetailsModel
@{
    ViewData["Title"] = "Transaction Details";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Transaction Details</h1>
            <p>Review the payment record, billing details, gateway status, and issue a refund if needed.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn btn-secondary btn-sm" href="~/Admin/Transactions">&#8592; Back to Transactions</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="message success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="message error">@errorMessage</div>
    }

    @if (Model.Transaction is null)
    {
        <p>Transaction not found.</p>
    }
    else
    {
        <div class="card-grid">
            <article class="card">
                <h3>@Model.Transaction.CustomerName</h3>
                <p>@Model.Transaction.CustomerEmail</p>
            </article>
            <article class="card">
                <h3>@Model.Transaction.Amount.ToString("C")</h3>
                <p>@Model.Transaction.StatusLabel</p>
            </article>
            <article class="card">
                <h3>@(string.IsNullOrWhiteSpace(Model.Transaction.TransactionId) ? "—" : Model.Transaction.TransactionId)</h3>
                <p>Authorize.Net transaction ID</p>
            </article>
            <article class="card">
                <h3>@Model.Transaction.AssociationName</h3>
                <p>@Model.Transaction.SourceLabel</p>
            </article>
        </div>

        <div class="card-grid">
            <article class="card">
                <h3>Payment Record</h3>
                <p><strong>Type:</strong> @Model.Transaction.SourceType</p>
                <p><strong>Card:</strong> @(string.IsNullOrWhiteSpace(Model.Transaction.CardLast4) ? "—" : $"**** {Model.Transaction.CardLast4}")</p>
                <p><strong>Paid:</strong> @(Model.Transaction.PaidAtUtc.HasValue ? Model.Transaction.PaidAtUtc.Value.ToString("MMM d, yyyy h:mm tt") : "—")</p>
                <p>
                    <strong>Refund:</strong>
                    @if (Model.Transaction.IsRefunded)
                    {
                        <span class="status-badge status-badge--yellow">@(Model.Transaction.RefundAmount.HasValue ? Model.Transaction.RefundAmount.Value.ToString("C") : "Refunded")</span>
                    }
                    else
                    {
                        <span>None</span>
                    }
                </p>
            </article>
            <article class="card">
                <h3>Billing Address</h3>
                <p>@Model.Transaction.BillingAddressLine1</p>
                <p>@Model.Transaction.BillingCity, @Model.Transaction.BillingState @Model.Transaction.BillingZipCode</p>
                <p>@Model.Transaction.BillingCountry</p>
            </article>
            <article class="card">
                <h3>Gateway Details</h3>
                @if (Model.Transaction.GatewayDetails is null)
                {
                    <p class="text-muted">Gateway details unavailable for this transaction.</p>
                }
                else
                {
                    <p><strong>Status:</strong> @Model.Transaction.GatewayDetails.TransactionStatus</p>
                    <p><strong>Type:</strong> @Model.Transaction.GatewayDetails.TransactionType</p>
                    <p><strong>Card:</strong> @(string.IsNullOrWhiteSpace(Model.Transaction.GatewayDetails.CardLast4) ? "—" : $"**** {Model.Transaction.GatewayDetails.CardLast4}")</p>
                    <p><strong>Batch:</strong> @(string.IsNullOrWhiteSpace(Model.Transaction.GatewayDetails.BatchId) ? "—" : Model.Transaction.GatewayDetails.BatchId)</p>
                    <p><strong>Response:</strong> @(string.IsNullOrWhiteSpace(Model.Transaction.GatewayDetails.ResponseDescription) ? "—" : Model.Transaction.GatewayDetails.ResponseDescription)</p>
                }
            </article>
        </div>

        <div class="section-panel" style="margin-top:1rem;">
            <h2>Issue Refund</h2>
            @if (Model.Transaction.IsRefunded)
            {
                <p>This transaction has already been refunded.</p>
            }
            else if (string.IsNullOrWhiteSpace(Model.Transaction.CardLast4))
            {
                <p>No saved card reference is available — this transaction cannot be refunded from the application. Contact Authorize.Net directly.</p>
            }
            else
            {
                <form method="post" asp-page-handler="Refund" asp-route-sourceType="@Model.SourceType" asp-route-id="@Model.Id" class="admin-filter-bar">
                    <div>
                        <label for="amount">Refund Amount</label>
                        <input id="amount" asp-for="Input.Amount" class="form-control" placeholder="Leave blank for full amount" />
                        <span asp-validation-for="Input.Amount" class="text-danger"></span>
                    </div>
                    <div>
                        <label for="reason">Reason (internal note)</label>
                        <input id="reason" asp-for="Input.Reason" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="admin-filter-bar__actions">
                        <button type="submit" class="btn">Process Refund</button>
                    </div>
                </form>
                <p class="field-note">Leave the amount blank to refund the full transaction amount.</p>
            }
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/Admin/Transactions">&#8592; Back to Transactions</a>
        <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
    </div>
</section>
