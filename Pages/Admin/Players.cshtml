@page
@model GolfAssociationCommunity.Pages.Admin.PlayersModel
@{
    ViewData["Title"] = "Manage Players";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Players</h1>
            <p>Search and manage players across all associations. Delete a player to remove their records from every association.</p>
        </div>
        <div class="admin-page-header__actions">
            <a href="?handler=DownloadCsv" class="btn btn-secondary btn-sm">&#8595; Download CSV</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    @if (Model.Players.Count == 0)
    {
        <p>No players found.</p>
    }
    else
    {
        <form id="bulk-player-delete" method="post" asp-page-handler="DeleteSelected">
            <input type="hidden" name="Search" value="@Model.Search" />
        </form>
        <div class="table-toolbar">
            <label class="table-toolbar__select-all">
                <input type="checkbox" id="select-all-players" /> Select all visible
            </label>
            <span id="admin-player-search-count" class="table-toolbar__count"></span>
        </div>
        <div class="table-scroll">
            <table class="table" id="admin-players-table">
                <thead>
                    <tr>
                        <th><span class="sr-only">Select</span></th>
                        <th>Actions</th>
                        <th>Player</th>
                        <th>Email</th>
                        <th>Associations</th>
                        <th title="Active association records">Active</th>
                        <th title="Archived association records">Archived</th>
                        <th>Registrations</th>
                        <th>Scores</th>
                        <th>Leaderboard Entries</th>
                        <th>Last Updated</th>
                    </tr>
                    <tr>
                        <th></th>
                        <th></th>
                        <th><input type="search" id="col-filter-name" class="form-control" placeholder="Filter name&hellip;" autocomplete="off" style="font-weight:normal;min-width:120px;" /></th>
                        <th><input type="search" id="col-filter-email" class="form-control" placeholder="Filter email&hellip;" autocomplete="off" style="font-weight:normal;min-width:150px;" /></th>
                        <th><input type="search" id="col-filter-assoc" class="form-control" placeholder="Filter association&hellip;" autocomplete="off" style="font-weight:normal;min-width:140px;" /></th>
                        <th colspan="6"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var player in Model.Players)
                {
                    var assocNames = string.Join(" ", player.Associations.Select(a => a.AssociationName)).ToLower();
                    <tr data-name="@player.DisplayName.ToLower()" data-email="@player.Email.ToLower()" data-assoc="@assocNames">
                        <td><input type="checkbox" class="player-check" name="EmailKeys" value="@player.EmailKey" form="bulk-player-delete" /></td>
                        <td>
                            <form method="post" asp-page-handler="Delete" asp-route-emailKey="@player.EmailKey" class="inline-form"
                                  onsubmit="return confirm('Delete this player from every association? All linked records will be permanently removed.');">
                                <input type="hidden" name="Search" value="@Model.Search" />
                                <button type="submit" class="link-button danger" title="Remove this player from all associations">Delete All</button>
                            </form>
                        </td>
                        <td>@player.DisplayName</td>
                        <td>@player.Email</td>
                        <td>
                            @foreach (var association in player.Associations)
                            {
                                <div>
                                    @association.AssociationName
                                    @if (association.IsActive)
                                    {
                                        <span class="status-badge status-badge--green">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-badge--gray">Archived</span>
                                    }
                                </div>
                            }
                        </td>
                        <td>@player.ActiveCount</td>
                        <td>@player.ArchivedCount</td>
                        <td>@player.RegistrationCount</td>
                        <td>@player.ScoreCount</td>
                        <td>@player.LeaderboardCount</td>
                        <td>@(player.LastUpdatedAt.HasValue ? player.LastUpdatedAt.Value.ToString("MMM d, yyyy h:mm tt") : "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
            <button type="submit" form="bulk-player-delete" class="btn btn-danger"
                    onclick="return document.querySelectorAll('.player-check:checked').length > 0 || (alert('Select at least one player first.'), false)">
                Delete Selected Players
            </button>
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
    </div>
</section>
<script>
function filterAdminPlayers() {
    var qName  = (document.getElementById('col-filter-name')?.value  || '').trim().toLowerCase();
    var qEmail = (document.getElementById('col-filter-email')?.value || '').trim().toLowerCase();
    var qAssoc = (document.getElementById('col-filter-assoc')?.value || '').trim().toLowerCase();
    var searchCount = document.getElementById('admin-player-search-count');
    var rows = document.querySelectorAll('#admin-players-table tbody tr');
    var visible = 0;
    var anyFilter = qName || qEmail || qAssoc;
    rows.forEach(function(row) {
        var name  = (row.dataset.name  || '');
        var email = (row.dataset.email || '');
        var assoc = (row.dataset.assoc || '');
        var match = (!qName  || name.indexOf(qName)   >= 0) &&
                    (!qEmail || email.indexOf(qEmail)  >= 0) &&
                    (!qAssoc || assoc.indexOf(qAssoc)  >= 0);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
        if (!match) {
            var cb = row.querySelector('.player-check');
            if (cb) cb.checked = false;
        }
    });
    if (searchCount) searchCount.textContent = anyFilter ? visible + ' result' + (visible !== 1 ? 's' : '') : '';
}

var _adminSelectAll = document.getElementById('select-all-players');
if (_adminSelectAll) {
    _adminSelectAll.addEventListener('change', function() {
        var isChecked = this.checked;
        document.querySelectorAll('#admin-players-table tbody tr:not([style*="display: none"]) .player-check').forEach(function(cb) { cb.checked = isChecked; });
    });
}
document.querySelectorAll('.player-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
        var all = document.getElementById('select-all-players');
        if (!all) return;
        var checks  = document.querySelectorAll('.player-check');
        var checked = document.querySelectorAll('.player-check:checked');
        all.indeterminate = checked.length > 0 && checked.length < checks.length;
        all.checked = checks.length > 0 && checked.length === checks.length;
    });
});

['col-filter-name','col-filter-email','col-filter-assoc'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', filterAdminPlayers);
});
</script>
