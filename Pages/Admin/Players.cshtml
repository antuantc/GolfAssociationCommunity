@page
@model GolfAssociationCommunity.Pages.Admin.PlayersModel
@{
    ViewData["Title"] = "Manage Players";
}

<section class="section-panel">
    <h1>Manage Players</h1>
    <p>Search players across all associations and remove them everywhere when needed.</p>

    <div class="players-section-header" style="margin-bottom:0.75rem;">
        <input type="search" id="admin-player-search" class="form-control search-inline"
               placeholder="&#128269; Name, email, or association&hellip;" autocomplete="off"
               oninput="filterAdminPlayers(this)" style="max-width:340px;" />
        <span id="admin-player-search-count" class="table-toolbar__count"></span>
    </div>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    @if (Model.Players.Count == 0)
    {
        <p>No players found.</p>
    }
    else
    {
        <form id="bulk-player-delete" method="post" asp-page-handler="DeleteSelected">
            <input type="hidden" name="Search" value="@Model.Search" />
        </form>
        <div class="table-scroll">
            <table class="table" id="admin-players-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="select-all-players" title="Select all" /></th>
                        <th>Player</th>
                        <th>Email</th>
                        <th>Associations</th>
                        <th>Active</th>
                        <th>Archived</th>
                        <th>Registrations</th>
                        <th>Scores</th>
                        <th>Leaderboards</th>
                        <th>Last Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var player in Model.Players)
                {
                    var assocNames = string.Join(" ", player.Associations.Select(a => a.AssociationName)).ToLower();
                    <tr data-name="@player.DisplayName.ToLower()" data-email="@player.Email.ToLower()" data-assoc="@assocNames">
                        <td><input type="checkbox" class="player-check" name="EmailKeys" value="@player.EmailKey" form="bulk-player-delete" /></td>
                        <td>@player.DisplayName</td>
                        <td>@player.Email</td>
                        <td>
                            @foreach (var association in player.Associations)
                            {
                                <div>@association.AssociationName @(association.IsActive ? "(Active)" : "(Archived)")</div>
                            }
                        </td>
                        <td>@player.ActiveCount</td>
                        <td>@player.ArchivedCount</td>
                        <td>@player.RegistrationCount</td>
                        <td>@player.ScoreCount</td>
                        <td>@player.LeaderboardCount</td>
                        <td>@(player.LastUpdatedAt.HasValue ? player.LastUpdatedAt.Value.ToString("MMM d, yyyy h:mm tt") : "-")</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" asp-route-emailKey="@player.EmailKey" class="inline-form" onsubmit="return confirm('Delete this player from every association? This will remove linked player records across the platform.');">
                                <input type="hidden" name="Search" value="@Model.Search" />
                                <button type="submit" class="link-button">Delete All</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
            <button type="submit" form="bulk-player-delete" class="btn btn-danger"
                    onclick="return document.querySelectorAll('.player-check:checked').length > 0 || (alert('Select at least one player.'), false)">
                Delete Selected
            </button>
        </div>
    }
</section>
<script>
    document.getElementById('select-all-players')?.addEventListener('change', function () {
        document.querySelectorAll('#admin-players-table tbody tr:not([style*="display: none"]) .player-check').forEach(cb => cb.checked = this.checked);
    });
    document.querySelectorAll('.player-check').forEach(cb => cb.addEventListener('change', function () {
        const all = document.getElementById('select-all-players');
        if (!all) return;
        const checks = document.querySelectorAll('.player-check');
        const checked = document.querySelectorAll('.player-check:checked');
        all.indeterminate = checked.length > 0 && checked.length < checks.length;
        all.checked = checks.length > 0 && checked.length === checks.length;
    }));
    function filterAdminPlayers(input) {
        const q = input.value.trim().toLowerCase();
        const searchCount = document.getElementById('admin-player-search-count');
        const rows = document.querySelectorAll('#admin-players-table tbody tr');
        let visible = 0;
        rows.forEach(row => {
            const match = !q ||
                (row.dataset.name  || '').includes(q) ||
                (row.dataset.email || '').includes(q) ||
                (row.dataset.assoc || '').includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visible++;
            if (!match) {
                const cb = row.querySelector('.player-check');
                if (cb) cb.checked = false;
            }
        });
        if (searchCount) searchCount.textContent = q ? visible + ' result' + (visible !== 1 ? 's' : '') : '';
    }
</script>
