@page "{id:int}"
@model GolfAssociationCommunity.Pages.Admin.AssociationMembersModel
@{
    ViewData["Title"] = "Association Members";
}

<section class="section-panel">
    <h1>@Model.Association?.Name</h1>
    <p>Member count: <strong>@Model.MemberCount</strong></p>
    <p>Current admin user ID: <strong>@(Model.Association?.AdminUserId ?? "Not assigned")</strong></p>

    @if (TempData["SuccessMessage"] is string message)
    {
        <div class="message success">@message</div>
    }

    <h2>Add Member by User ID</h2>
    <form method="post" asp-page-handler="Add">
        <div asp-validation-summary="ModelOnly" class="message error"></div>
        <label asp-for="Input.UserId"></label>
        <input asp-for="Input.UserId" class="form-control" />
        <span asp-validation-for="Input.UserId" class="text-danger"></span>
        <button type="submit" class="btn">Add Member</button>
    </form>
</section>

<section class="section-panel">
    <h2>Current Members</h2>
    @if (Model.Members.Count == 0)
    {
        <p>No members assigned.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>User ID</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var member in Model.Members)
            {
                <tr>
                    <td>@member.FirstName @member.LastName</td>
                    <td>@member.Email</td>
                    <td>@member.Id</td>
                    <td>
                        <form method="post" asp-page-handler="SetAssociationAdmin" asp-route-userId="@member.Id" class="inline-form">
                            <button type="submit" class="link-button">Set as Association Admin</button>
                        </form>
                        <form method="post" asp-page-handler="Remove" asp-route-userId="@member.Id" class="inline-form" onsubmit="return confirm('Remove this member from the association?');">
                            <button type="submit" class="link-button">Remove</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

<section class="section-panel">
    <h2>Tournaments for Association</h2>
    @if (Model.Tournaments.Count == 0)
    {
        <p>No tournaments found.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Start</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var tournament in Model.Tournaments)
            {
                <tr>
                    <td>@tournament.Name</td>
                    <td>@tournament.StartDate.ToString("MMM d, yyyy")</td>
                    <td>@tournament.Status</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <a class="btn btn-secondary" href="~/Admin/Associations">Back to Associations</a>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
