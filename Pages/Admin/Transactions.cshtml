@page
@model GolfAssociationCommunity.Pages.Admin.TransactionsModel
@{
    ViewData["Title"] = "Transactions";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Transactions</h1>
            <p>Review payment activity across all associations. Open any transaction to reconcile or issue a refund.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="message success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="message error">@errorMessage</div>
    }

    <form method="get" class="admin-filter-bar">
        <div>
            <label for="search">Search</label>
            <input id="search" name="Search" value="@Model.Search" class="form-control" placeholder="Transaction ID, customer, or association" />
        </div>
        <div class="admin-filter-bar__actions">
            <button type="submit" class="btn btn-sm">Apply Filters</button>
            <a class="btn btn-secondary btn-sm" href="~/Admin/Transactions">Reset</a>
        </div>
    </form>

    <div class="card-grid">
        <article class="card">
            <h3>@Model.Transactions.Count</h3>
            <p>Transactions shown</p>
        </article>
        <article class="card">
            <h3>@Model.TotalAmount.ToString("C")</h3>
            <p>Total captured</p>
        </article>
        <article class="card">
            <h3>@Model.RefundedAmount.ToString("C")</h3>
            <p>Total refunded</p>
        </article>
        <article class="card">
            <h3>@Model.RefundedCount</h3>
            <p>Refunded records</p>
        </article>
    </div>

    @if (Model.Transactions.Count == 0)
    {
        <p>No transactions found matching the current filters.</p>
    }
    else
    {
        <div class="table-scroll">
        <table class="table">
            <thead>
                <tr>
                    <th>Actions</th>
                    <th>Association</th>
                    <th>Type</th>
                    <th>Customer</th>
                    <th>Source</th>
                    <th>Paid</th>
                    <th>Status</th>
                    <th>Amount</th>
                    <th>Card</th>
                    <th>Refund</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var transaction in Model.Transactions)
            {
                <tr>
                    <td>
                        <a class="card-link" asp-page="/Admin/Transactions/Details" asp-route-sourceType="@transaction.SourceType" asp-route-id="@transaction.SourceId"
                           title="View full transaction details and refund options">View Details</a>
                    </td>
                    <td>@transaction.AssociationName</td>
                    <td>@transaction.SourceType</td>
                    <td>
                        <strong>@transaction.CustomerName</strong><br />
                        <small>@transaction.CustomerEmail</small>
                    </td>
                    <td>@transaction.SourceLabel</td>
                    <td>@(transaction.PaidAtUtc.HasValue ? transaction.PaidAtUtc.Value.ToString("MMM d, yyyy") : "—")</td>
                    <td>@transaction.StatusLabel</td>
                    <td>@transaction.Amount.ToString("C")</td>
                    <td>@(string.IsNullOrWhiteSpace(transaction.CardLast4) ? "—" : $"**** {transaction.CardLast4}")</td>
                    <td>
                        @if (transaction.IsRefunded)
                        {
                            <span class="status-badge status-badge--yellow">@(transaction.RefundAmount.HasValue ? transaction.RefundAmount.Value.ToString("C") : "Refunded")</span><br />
                            @if (transaction.RefundedAtUtc.HasValue)
                            {
                                <small class="text-muted">@transaction.RefundedAtUtc.Value.ToString("MMM d, yyyy")</small>
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/Admin">&#8592; Back to Dashboard</a>
    </div>
</section>
