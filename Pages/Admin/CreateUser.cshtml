@page
@model GolfAssociationCommunity.Pages.Admin.CreateUserModel
@{
    ViewData["Title"] = "Create User";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Create User</h1>
            <p>Create a new user account and optionally assign a role and association.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn btn-secondary btn-sm" href="~/Admin/Users">&#8592; Back to Users</a>
        </div>
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="message error"></div>

        <h2 class="form-section-title">Account Details</h2>
        <div class="card-grid">
            <div>
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.FirstName"></label>
                <input asp-for="Input.FirstName" class="form-control" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.LastName"></label>
                <input asp-for="Input.LastName" class="form-control" />
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" class="form-control" type="password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.Role">Role</label>
                <select asp-for="Input.Role" class="form-control">
                    <option value="Member">Standard User — can register for tournaments</option>
                    <option value="AssociationAdmin">Association Admin — manages one association</option>
                    <option value="Admin">Admin — full platform access</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.AssociationId">Association</label>
                <select asp-for="Input.AssociationId" class="form-control">
                    <option value="">None (platform-wide)</option>
                    @foreach (var association in Model.Associations)
                    {
                        <option value="@association.Id">@association.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.AssociationId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions" style="margin-top:1.5rem;">
            <button type="submit" class="btn">Create User</button>
            <a class="btn btn-secondary" href="~/Admin/Users">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}