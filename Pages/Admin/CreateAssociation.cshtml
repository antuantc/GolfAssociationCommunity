@page
@model GolfAssociationCommunity.Pages.Admin.CreateAssociationModel
@{
    ViewData["Title"] = "Create Association";
}

<div class="hero">
    <div class="hero-copy">
        <h1>Create Golf Association</h1>
        <p>Add a new association to the platform as an admin.</p>
    </div>
</div>

<section class="section-panel">
    <h2>Association Details</h2>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="message error"></div>

        <div class="card-grid">
            <div>
                <label asp-for="Input.Name"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.ContactEmail"></label>
                <input asp-for="Input.ContactEmail" class="form-control" />
                <span asp-validation-for="Input.ContactEmail" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.ContactPhone"></label>
                <input asp-for="Input.ContactPhone" class="form-control" />
                <span asp-validation-for="Input.ContactPhone" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.Website"></label>
                <input asp-for="Input.Website" class="form-control" />
                <span asp-validation-for="Input.Website" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.Street"></label>
                <input asp-for="Input.Street" class="form-control" />
                <span asp-validation-for="Input.Street" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.City"></label>
                <input asp-for="Input.City" class="form-control" />
                <span asp-validation-for="Input.City" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.State"></label>
                <input asp-for="Input.State" class="form-control" />
                <span asp-validation-for="Input.State" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.ZipCode"></label>
                <input asp-for="Input.ZipCode" class="form-control" />
                <span asp-validation-for="Input.ZipCode" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.Country"></label>
                <input asp-for="Input.Country" class="form-control" />
                <span asp-validation-for="Input.Country" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.LogoUrl"></label>
                <input asp-for="Input.LogoUrl" class="form-control" />
                <span asp-validation-for="Input.LogoUrl" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Input.Description" class="text-danger"></span>
        </div>

        <h2>Association Admin (Optional)</h2>
        <p>Provide these fields to create and assign an association admin account now.</p>

        <div class="card-grid">
            <div>
                <label asp-for="Input.AssociationAdminEmail"></label>
                <input asp-for="Input.AssociationAdminEmail" class="form-control" />
                <span asp-validation-for="Input.AssociationAdminEmail" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.AssociationAdminPassword"></label>
                <input asp-for="Input.AssociationAdminPassword" class="form-control" />
                <span asp-validation-for="Input.AssociationAdminPassword" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.AssociationAdminFirstName"></label>
                <input asp-for="Input.AssociationAdminFirstName" class="form-control" />
                <span asp-validation-for="Input.AssociationAdminFirstName" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Input.AssociationAdminLastName"></label>
                <input asp-for="Input.AssociationAdminLastName" class="form-control" />
                <span asp-validation-for="Input.AssociationAdminLastName" class="text-danger"></span>
            </div>
        </div>

        <button type="submit" class="btn">Create Association</button>
        <a href="~/Admin" class="btn btn-secondary">Back to Admin</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
