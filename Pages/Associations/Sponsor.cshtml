@page "{id:int}"
@model GolfAssociationCommunity.Pages.Associations.SponsorModel
@{
    ViewData["Title"] = Model.Association?.Name is null ? "Sponsor Association" : $"Sponsor {Model.Association.Name}";
}

<section class="section-panel">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="message success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="message error">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Association == null)
    {
        <h1>Association not found</h1>
        <p>The association you requested does not exist or is not active.</p>
        <a href="~/" class="btn btn-secondary">Back to associations</a>
    }
    else if (Model.ActiveSponsorshipPackages.Count == 0)
    {
        <h1>Sponsorship Unavailable</h1>
        <p>This association does not currently have active sponsorship packages.</p>
        <a href="~/Associations/Details/@Model.Association.Id" class="btn btn-secondary">Back to association</a>
    }
    else
    {
        <h1>Sponsor @Model.Association.Name</h1>
        <p>Select a sponsorship package and complete payment.</p>

        <form method="post" autocomplete="on">
            <div asp-validation-summary="ModelOnly" class="message error"></div>

            <div class="form-shell">
                <div class="form-section">
                    <h3 class="form-section-title">Sponsorship Selection</h3>
                    <div class="pkg-option-cards">
                        @foreach (var package in Model.ActiveSponsorshipPackages)
                        {
                            <div class="pkg-option-card @(package.Id == Model.Input.SponsorshipPackageId ? "selected" : "")"
                                 data-pkg-id="@package.Id"
                                 data-pkg-name="@Html.Encode(package.Name)"
                                 data-pkg-amount="@package.Amount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                 onclick="selectPkg(this)">
                                <div class="pkg-option-card__name">@package.Name</div>
                                <div class="pkg-option-card__amount">@package.Amount.ToString("C")</div>
                                @if (!string.IsNullOrWhiteSpace(package.Description))
                                {
                                    <div class="pkg-option-card__desc">@package.Description</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(package.Benefits))
                                {
                                    <ul class="pkg-option-card__benefits">
                                        @foreach (var b in package.Benefits.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <li>@b.Trim()</li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    </div>
                    <input type="hidden" asp-for="Input.SponsorshipPackageId" id="pkgIdInput" />
                    <span asp-validation-for="Input.SponsorshipPackageId" class="text-danger"></span>

                    <div class="form-grid" style="margin-top:1rem;">
                        <div>
                    <label asp-for="Input.SponsorName">Sponsor Name</label>
                    <input asp-for="Input.SponsorName" class="form-control" autocomplete="name" />
                    <span asp-validation-for="Input.SponsorName" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.SponsorEmail">Sponsor Email</label>
                    <input asp-for="Input.SponsorEmail" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Input.SponsorEmail" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.SponsorCompany">Company (Optional)</label>
                    <input asp-for="Input.SponsorCompany" class="form-control" autocomplete="organization" />
                    <span asp-validation-for="Input.SponsorCompany" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h3 class="form-section-title">Payment Details</h3>
                    <div class="security-note">Card details are sent directly for authorization and are not stored in full.</div>

                    <div class="form-grid">
                        <div class="full">
                    <label asp-for="Input.CardholderName">Cardholder Name</label>
                    <input asp-for="Input.CardholderName" class="form-control" autocomplete="cc-name" />
                    <span asp-validation-for="Input.CardholderName" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.CardNumber">Card Number <span class="card-type-badge" id="sponsorCardTypeBadge" style="display:none;"></span></label>
                    <input asp-for="Input.CardNumber" class="form-control" inputmode="numeric" autocomplete="cc-number" placeholder="0000 0000 0000 0000" />
                    <span asp-validation-for="Input.CardNumber" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.CardExpiry">Expiry (MM/YY)</label>
                    <input asp-for="Input.CardExpiry" class="form-control" inputmode="numeric" autocomplete="cc-exp" placeholder="MM/YY" />
                    <span asp-validation-for="Input.CardExpiry" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.Cvv">CVV</label>
                    <input asp-for="Input.Cvv" type="password" class="form-control" inputmode="numeric" autocomplete="cc-csc" maxlength="4" />
                    <span asp-validation-for="Input.Cvv" class="text-danger"></span>
                        </div>
                        <div class="full">
                    <label asp-for="Input.BillingAddressLine1">Billing Address</label>
                    <input asp-for="Input.BillingAddressLine1" class="form-control" autocomplete="billing address-line1" />
                    <span asp-validation-for="Input.BillingAddressLine1" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.BillingCity">City</label>
                    <input asp-for="Input.BillingCity" class="form-control" autocomplete="billing address-level2" />
                    <span asp-validation-for="Input.BillingCity" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.BillingState">State/Province</label>
                    <input asp-for="Input.BillingState" class="form-control" autocomplete="billing address-level1" />
                    <span asp-validation-for="Input.BillingState" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.BillingZipCode">Postal Code</label>
                    <input asp-for="Input.BillingZipCode" class="form-control" autocomplete="billing postal-code" />
                    <span asp-validation-for="Input.BillingZipCode" class="text-danger"></span>
                        </div>
                        <div>
                    <label asp-for="Input.BillingCountry">Country</label>
                    <input asp-for="Input.BillingCountry" class="form-control" autocomplete="billing country" />
                    <span asp-validation-for="Input.BillingCountry" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                @{
                    var _selPkg = Model.ActiveSponsorshipPackages.FirstOrDefault(p => p.Id == Model.Input.SponsorshipPackageId);
                }
                <div class="checkout-summary" id="sponsorSummary" style="@(_selPkg == null ? "display:none;" : "")">
                    <div class="checkout-summary__title">Order Summary</div>
                    <div class="checkout-summary__row">
                        <span id="summaryPkgName">@(_selPkg?.Name ?? "")</span>
                        <span id="summaryPkgAmount">@(_selPkg?.Amount.ToString("C") ?? "")</span>
                    </div>
                    <div class="checkout-summary__total">
                        <span>Total Due</span>
                        <strong id="sponsorTotal">@(_selPkg?.Amount.ToString("C") ?? "")</strong>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn" id="sponsorSubmitBtn">
                        <span id="sponsorSubmitLabel">@(_selPkg != null ? $"Pay {_selPkg.Amount.ToString("C")}" : "Pay and Sponsor")</span>
                        <span class="btn-spinner" id="sponsorSpinner" style="display:none;"></span>
                    </button>
                    <a class="btn btn-secondary" href="~/Associations/Details/@Model.Association.Id">Back to association</a>
                </div>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function selectPkg(el) {
            var id = parseInt(el.dataset.pkgId);
            var name = el.dataset.pkgName;
            var amount = parseFloat(el.dataset.pkgAmount);
            document.querySelectorAll('.pkg-option-card').forEach(function (c) {
                c.classList.toggle('selected', parseInt(c.dataset.pkgId) === id);
            });
            var hidden = document.getElementById('pkgIdInput');
            if (hidden) hidden.value = id;
            var summary = document.getElementById('sponsorSummary');
            var pkgName = document.getElementById('summaryPkgName');
            var pkgAmount = document.getElementById('summaryPkgAmount');
            var total = document.getElementById('sponsorTotal');
            var label = document.getElementById('sponsorSubmitLabel');
            var fmt = '$' + amount.toFixed(2);
            if (summary) summary.style.display = '';
            if (pkgName) pkgName.textContent = name;
            if (pkgAmount) pkgAmount.textContent = fmt;
            if (total) total.textContent = fmt;
            if (label) label.textContent = 'Pay ' + fmt;
        }

        (function () {
            var cardNumberInput = document.getElementById('Input_CardNumber');
            var cardExpiryInput = document.getElementById('Input_CardExpiry');
            var cardTypeBadge = document.getElementById('sponsorCardTypeBadge');

            function detectCardType(d) {
                if (/^4/.test(d)) return 'Visa';
                if (/^5[1-5]|^2[2-7]/.test(d)) return 'Mastercard';
                if (/^3[47]/.test(d)) return 'Amex';
                if (/^6(?:011|5)/.test(d)) return 'Discover';
                return '';
            }

            if (cardNumberInput) {
                cardNumberInput.addEventListener('input', function (e) {
                    var digits = e.target.value.replace(/\D/g, '').slice(0, 16);
                    e.target.value = digits.replace(/(.{4})/g, '$1 ').trim();
                    if (cardTypeBadge) {
                        var type = detectCardType(digits);
                        cardTypeBadge.textContent = type;
                        cardTypeBadge.style.display = type ? '' : 'none';
                    }
                });
            }

            if (cardExpiryInput) {
                cardExpiryInput.addEventListener('input', function (e) {
                    var digits = e.target.value.replace(/\D/g, '').slice(0, 4);
                    e.target.value = digits.length > 2 ? digits.slice(0, 2) + '/' + digits.slice(2) : digits;
                });
            }

            var sponsorSubmitBtn = document.getElementById('sponsorSubmitBtn');
            if (sponsorSubmitBtn) {
                sponsorSubmitBtn.closest('form').addEventListener('submit', function () {
                    sponsorSubmitBtn.disabled = true;
                    var spinner = document.getElementById('sponsorSpinner');
                    var label = document.getElementById('sponsorSubmitLabel');
                    if (spinner) spinner.style.display = 'inline-block';
                    if (label) label.textContent = 'Processing\u2026';
                });
            }
        })();
    </script>
}
