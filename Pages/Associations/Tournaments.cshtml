@page
@model GolfAssociationCommunity.Pages.Associations.TournamentsModel
@{
    ViewData["Title"] = Model.Association?.Name is null ? "Association Tournaments" : $"{Model.Association.Name} Tournaments";
}

<section class="section-panel">
    @if (Model.Association == null)
    {
        <h1>Association not found</h1>
        <p>The association you requested does not exist or is not active.</p>
        <a href="~/" class="btn btn-secondary">Back to associations</a>
    }
    else
    {
        <h1>@Model.Association.Name Tournaments</h1>
        <p>Browse tournaments for this association only.</p>

        <div class="section-panel">
            <h2>Upcoming Tournaments</h2>
            @if (Model.UpcomingTournaments.Count == 0)
            {
                <p>No upcoming tournaments are available for this association.</p>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var tournament in Model.UpcomingTournaments)
                    {
                        <article class="card">
                            <h3>@tournament.Name</h3>
                            <p>@tournament.Description</p>
                            <dl class="details-list">
                                <dt>Dates</dt>
                                <dd>@tournament.StartDate.ToString("MMM d, yyyy") - @tournament.EndDate.ToString("MMM d, yyyy")</dd>
                                <dt>Registration Deadline</dt>
                                <dd>@(tournament.RegistrationDeadline.HasValue ? tournament.RegistrationDeadline.Value.ToString("MMM d, yyyy") : "Not set")</dd>
                                <dt>Format</dt>
                                <dd>@tournament.Format</dd>
                                <dt>Location</dt>
                                <dd>@(string.IsNullOrWhiteSpace(tournament.Location) ? "TBD" : tournament.Location)</dd>
                                <dt>Golf Course</dt>
                                <dd>@(string.IsNullOrWhiteSpace(tournament.GolfCourse) ? "TBD" : tournament.GolfCourse)</dd>
                                <dt>Entry Fee</dt>
                                <dd>@tournament.EntryFee.ToString("C")</dd>
                                <dt>Max Players</dt>
                                <dd>@tournament.MaxPlayers</dd>
                                <dt>Status</dt>
                                <dd>@tournament.Status</dd>
                            </dl>
                            <a class="btn" href="~/Tournaments/Details/@tournament.Id?associationId=@Model.Association.Id">Register</a>
                        </article>
                    }
                </div>
            }
        </div>

        <div class="section-panel">
            <h2>Past Tournaments</h2>
            @if (Model.CompletedTournaments.Count == 0)
            {
                <p>No completed tournaments are available for this association.</p>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var tournament in Model.CompletedTournaments)
                    {
                        <article class="card">
                            <h3>@tournament.Name</h3>
                            <p>@tournament.Description</p>
                            <dl class="details-list">
                                <dt>Dates</dt>
                                <dd>@tournament.StartDate.ToString("MMM d, yyyy") - @tournament.EndDate.ToString("MMM d, yyyy")</dd>
                                <dt>Registration Deadline</dt>
                                <dd>@(tournament.RegistrationDeadline.HasValue ? tournament.RegistrationDeadline.Value.ToString("MMM d, yyyy") : "Not set")</dd>
                                <dt>Format</dt>
                                <dd>@tournament.Format</dd>
                                <dt>Location</dt>
                                <dd>@(string.IsNullOrWhiteSpace(tournament.Location) ? "TBD" : tournament.Location)</dd>
                                <dt>Golf Course</dt>
                                <dd>@(string.IsNullOrWhiteSpace(tournament.GolfCourse) ? "TBD" : tournament.GolfCourse)</dd>
                                <dt>Entry Fee</dt>
                                <dd>@tournament.EntryFee.ToString("C")</dd>
                                <dt>Max Players</dt>
                                <dd>@tournament.MaxPlayers</dd>
                                <dt>Status</dt>
                                <dd>@tournament.Status</dd>
                            </dl>
                            <a class="btn" href="~/Tournaments/Details/@tournament.Id?associationId=@Model.Association.Id">Register</a>
                        </article>
                    }
                </div>
            }
        </div>

        <a href="~/Associations/Details/@Model.Association.Id" class="btn btn-secondary">Back to association</a>
    }
</section>