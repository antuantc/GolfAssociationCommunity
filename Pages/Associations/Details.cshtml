@page "{id:int}"
@model GolfAssociationCommunity.Pages.Associations.DetailsModel
@using GolfAssociationCommunity.Models
@{
    ViewData["Title"] = Model.Association?.Name ?? "Association";
    var assoc = Model.Association;
    var activeVideos = assoc?.MediaItems.Where(m => m.IsActive && m.MediaType == MediaType.Video).OrderBy(m => m.DisplayOrder).ToList();
    var activePhotos = assoc?.MediaItems.Where(m => m.IsActive && m.MediaType == MediaType.Photo).OrderBy(m => m.DisplayOrder).ToList();
    var heroHasVideo = !string.IsNullOrWhiteSpace(assoc?.HeroVideoUrl);
    var heroHasImage = !string.IsNullOrWhiteSpace(assoc?.HeroImageUrl);
    var heroClasses = "assoc-hero" + (heroHasVideo ? " assoc-hero--video" : (heroHasImage ? " assoc-hero--image" : ""));
    var heroStyle = (!heroHasVideo && heroHasImage) ? $"style=\"background-image:url('{assoc!.HeroImageUrl}');\"" : "";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="message success container" style="margin-bottom:0;">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="message error container" style="margin-bottom:0;">@TempData["ErrorMessage"]</div>
}

@if (assoc == null)
{
    <section class="section-panel">
        <h1>Association not found</h1>
        <p>The association you requested does not exist or is not active.</p>
        <a href="~/" class="btn btn-secondary">Back to associations</a>
    </section>
}
else
{
    @* ── Hero Banner ─────────────────────────────────────────────── *@
    <div class="@heroClasses" @heroStyle>
        @if (heroHasVideo)
        {
            <video class="assoc-hero__video-bg" autoplay muted loop playsinline>
                <source src="@assoc!.HeroVideoUrl" type="video/mp4" />
            </video>
        }
        <div class="assoc-hero__overlay">
            @if (!string.IsNullOrWhiteSpace(assoc.Tagline))
            {
                <p class="assoc-hero__eyebrow">@assoc.Tagline.ToUpperInvariant()</p>
            }
            <h1 class="assoc-hero__title">@assoc.Name</h1>
            @if (!string.IsNullOrWhiteSpace(assoc.Description))
            {
                <p class="assoc-hero__desc">@assoc.Description</p>
            }
            @if (!string.IsNullOrWhiteSpace(assoc.Motto))
            {
                <blockquote class="assoc-hero__motto">&ldquo;@assoc.Motto&rdquo;</blockquote>
            }
            <div class="form-actions" style="margin-top:1.5rem;">
                <a class="btn" href="~/Associations/Leaderboard/@assoc.Id">View Leaderboard</a>
                @if (Model.NextTournament != null)
                {
                    <a class="btn btn-secondary" href="~/Tournaments/Details/@Model.NextTournament.Id?associationId=@assoc.Id">Register Now</a>
                }
            </div>
            @{
                var heroBadgeParts = new System.Collections.Generic.List<string>();
                if (assoc.EstYear.HasValue) heroBadgeParts.Add($"EST. {assoc.EstYear}");
                var heroLoc = string.Join(", ", new[] { assoc.City, assoc.State }.Where(s => !string.IsNullOrWhiteSpace(s)));
                if (!string.IsNullOrWhiteSpace(heroLoc)) heroBadgeParts.Add(heroLoc.ToUpperInvariant());
            }
            @if (heroBadgeParts.Count > 0)
            {
                <p class="assoc-hero__badge">@string.Join(" · ", heroBadgeParts)</p>
            }
        </div>
    </div>

    @* ── Stats Bar ────────────────────────────────────────────────── *@
    <div class="assoc-stats-bar">
        <div class="assoc-stat">
            <span class="assoc-stat__num">@assoc.Tournaments.Count</span>
            <span class="assoc-stat__label">Tournaments</span>
        </div>
        <div class="assoc-stat">
            <span class="assoc-stat__num">@Model.UpcomingTournamentCount</span>
            <span class="assoc-stat__label">Upcoming</span>
        </div>
        @if (assoc.EstYear.HasValue && assoc.EstYear.Value > 1800)
        {
            <div class="assoc-stat">
                <span class="assoc-stat__num">@(DateTime.UtcNow.Year - assoc.EstYear.Value)+</span>
                <span class="assoc-stat__label">Years Strong</span>
            </div>
        }
    </div>

    @* ── Upcoming Events ──────────────────────────────────────────── *@
    @if (Model.UpcomingTournaments.Count > 0)
    {
        <section class="section-panel">
            <div class="form-actions" style="justify-content:space-between;margin-bottom:1rem;">
                <h2 style="margin:0;">Upcoming Events</h2>
                <a href="~/Associations/Leaderboard/@assoc.Id" class="btn btn-secondary">View All &rsaquo;</a>
            </div>
            <div class="card-grid">
                @foreach (var t in Model.UpcomingTournaments)
                {
                    <article class="card event-card">
                        <div class="event-card__badge">
                            <span class="pill">UPCOMING</span>
                            <span class="field-note">@t.StartDate.ToString("MMM d, yyyy")</span>
                        </div>
                        <h3>@t.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(t.GolfCourse)) { <p style="margin:0.25rem 0;">@t.GolfCourse</p> }
                        @if (!string.IsNullOrWhiteSpace(t.Location)) { <p class="field-note" style="margin:0 0 0.75rem;">@t.Location</p> }
                        <a class="btn" href="~/Tournaments/Details/@t.Id?associationId=@assoc.Id">Register &rarr;</a>
                    </article>
                }
            </div>
        </section>
    }

    @* ── Recent Tournament Results ─────────────────────────────────── *@
    @if (Model.RecentLeaderboards.Count > 0)
    {
        <section class="section-panel">
            <h2>Recent Tournament Results</h2>
            <div class="card-grid">
                @foreach (var lb in Model.RecentLeaderboards)
                {
                    <article class="card">
                        <h3>@lb.TournamentName</h3>
                        <p class="field-note">@lb.TournamentDates</p>
                        <table class="table" style="margin-top:0.5rem;">
                            <thead><tr><th>#</th><th>Player</th><th>Score</th></tr></thead>
                            <tbody>
                                @foreach (var e in lb.TopEntries)
                                {
                                    <tr>
                                        <td>@e.Position</td>
                                        <td>@(e.AssociationPlayer?.DisplayName ?? "Unknown")</td>
                                        <td>@e.TotalScore</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <a class="btn btn-secondary" href="~/Associations/Leaderboard/@assoc.Id?TournamentId=@lb.TournamentId">Full results</a>
                    </article>
                }
            </div>
        </section>
    }

    @* ── Videos ───────────────────────────────────────────────────── *@
    @if (activeVideos != null && activeVideos.Count > 0)
    {
        <section class="section-panel">
            <h2>Videos</h2>
            <div class="video-grid">
                @foreach (var item in activeVideos)
                {
                    var videoSrc = item.AutoPlay ? item.Url + (item.Url.Contains("youtube.com") ? "?autoplay=1&mute=1" : "?autoplay=1&muted=1") : item.Url;
                    <div class="video-item">
                        <div class="video-frame-wrap">
                            <iframe src="@videoSrc" class="gallery-video" allowfullscreen loading="lazy"
                                    title="@item.Caption"
                                    allow="autoplay; encrypted-media"></iframe>
                            <button class="video-fullscreen-btn" onclick="this.previousElementSibling.requestFullscreen()" title="Full screen" aria-label="Full screen">
                                &#x26F6;
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Caption))
                        {
                            <p class="gallery-caption">@item.Caption</p>
                        }
                    </div>
                }
            </div>
        </section>
    }

    @* ── Photo Gallery ─────────────────────────────────────────────── *@
    @if (activePhotos != null && activePhotos.Count > 0)
    {
        <section class="section-panel">
            <h2>Gallery</h2>
            <div class="gallery-grid">
                @foreach (var item in activePhotos)
                {
                    <div class="gallery-item">
                        <img src="@item.Url" alt="@item.Caption" class="gallery-photo" loading="lazy" />
                        @if (!string.IsNullOrWhiteSpace(item.Caption))
                        {
                            <p class="gallery-caption">@item.Caption</p>
                        }
                    </div>
                }
            </div>
        </section>
    }

    @* ── Officers & Members ───────────────────────────────────────── *@
    @if (assoc.OfficersAndMembers.Any(o => o.IsActive))
    {
        <section class="section-panel">
            <h2>Officers &amp; Members</h2>
            <div class="card-grid">
                @foreach (var officer in assoc.OfficersAndMembers.Where(o => o.IsActive).OrderBy(o => o.DisplayOrder).ThenBy(o => o.Name))
                {
                    <article class="card">
                        @if (!string.IsNullOrWhiteSpace(officer.PictureUrl))
                        {
                            <img src="@officer.PictureUrl" alt="@officer.Name"
                                 style="width:100%;height:200px;object-fit:contain;object-position:center top;background:#f4f4f4;border-radius:6px;margin-bottom:.75rem;" />
                        }
                        <h3>@officer.Name</h3>
                        <div class="card-meta"><span class="pill">@officer.Role</span></div>
                        @if (!string.IsNullOrWhiteSpace(officer.Bio)) { <p>@officer.Bio</p> }
                    </article>
                }
            </div>
        </section>
    }

    @* ── Charity ──────────────────────────────────────────────────── *@
    @if (!string.IsNullOrWhiteSpace(assoc.CharityName))
    {
        <section class="section-panel charity-panel">
            <div class="charity-icon">&#9829;</div>
            <div>
                <h2 style="margin:0 0 0.5rem;">@assoc.CharityName</h2>
                @if (!string.IsNullOrWhiteSpace(assoc.CharityDescription)) { <p>@assoc.CharityDescription</p> }
                @if (!string.IsNullOrWhiteSpace(assoc.CharityUrl))
                {
                    <a href="@assoc.CharityUrl" target="_blank" rel="noopener noreferrer" class="btn">Learn More</a>
                }
            </div>
        </section>
    }

    @* ── Sponsors ─────────────────────────────────────────────────── *@
    @if (assoc.Sponsors.Any(s => s.IsActive))
    {
        <section class="section-panel">
            <h2>@DateTime.UtcNow.Year Sponsors</h2>
            <div class="sponsor-grid">
                @foreach (var s in assoc.Sponsors.Where(s => s.IsActive).OrderBy(s => s.DisplayOrder).ThenBy(s => s.Name))
                {
                    var sponsorTag = string.IsNullOrWhiteSpace(s.Website) ? "div" : "a";
                    @if (!string.IsNullOrWhiteSpace(s.Website))
                    {
                        <a href="@s.Website" target="_blank" rel="noopener noreferrer" class="sponsor-card">
                            @if (!string.IsNullOrWhiteSpace(s.LogoUrl))
                            {
                                <img src="@s.LogoUrl" alt="@s.Name" class="sponsor-logo" />
                            }
                            else
                            {
                                <div class="sponsor-initials">@(s.Name.Length >= 2 ? s.Name[..2].ToUpperInvariant() : s.Name.ToUpperInvariant())</div>
                            }
                            <span class="sponsor-name">@s.Name</span>
                            @if (!string.IsNullOrWhiteSpace(s.Category)) { <span class="sponsor-category">@s.Category</span> }
                        </a>
                    }
                    else
                    {
                        <div class="sponsor-card">
                            @if (!string.IsNullOrWhiteSpace(s.LogoUrl))
                            {
                                <img src="@s.LogoUrl" alt="@s.Name" class="sponsor-logo" />
                            }
                            else
                            {
                                <div class="sponsor-initials">@(s.Name.Length >= 2 ? s.Name[..2].ToUpperInvariant() : s.Name.ToUpperInvariant())</div>
                            }
                            <span class="sponsor-name">@s.Name</span>
                            @if (!string.IsNullOrWhiteSpace(s.Category)) { <span class="sponsor-category">@s.Category</span> }
                        </div>
                    }
                }
            </div>
        </section>
    }

    @* ── Become a Sponsor (packages) ──────────────────────────────── *@
    @if (Model.ActiveSponsorshipPackages.Count > 0)
    {
        <section class="section-panel">
            <h2>Become a Sponsor</h2>
            <p>Support this association and grow your business. Choose a level below.</p>
            <div class="card-grid">
                @foreach (var package in Model.ActiveSponsorshipPackages)
                {
                    <article class="card">
                        <h3>@package.Name</h3>
                        <p>@(string.IsNullOrWhiteSpace(package.Description) ? "Support this association as a sponsor." : package.Description)</p>
                        <div class="card-meta"><span>Contribution: @package.Amount.ToString("C")</span></div>
                        <p>@package.Benefits</p>
                        <a class="btn" href="~/Associations/Sponsor/@assoc.Id?selectedPackageId=@package.Id">Sponsor this package</a>
                    </article>
                }
            </div>
        </section>
    }

    @* ── All Tournaments ──────────────────────────────────────────── *@
    <section class="section-panel">
        <div class="form-actions" style="justify-content:space-between;margin-bottom:1rem;">
            <h2 style="margin:0;">All Tournaments</h2>
            <a href="~/Associations/Leaderboard/@assoc.Id" class="btn btn-secondary">Leaderboard</a>
        </div>
        @if (assoc.Tournaments == null || assoc.Tournaments.Count == 0)
        {
            <p>No tournaments are currently scheduled.</p>
        }
        else
        {
            <div class="card-grid">
                @foreach (var tournament in assoc.Tournaments.OrderBy(t => t.StartDate))
                {
                    <article class="card event-card">
                        <div class="event-card__badge">
                            <span class="pill">@tournament.Status</span>
                            <span class="field-note">@tournament.StartDate.ToString("MMM d, yyyy")</span>
                        </div>
                        <h3>@tournament.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(tournament.GolfCourse)) { <p style="margin:0.25rem 0;">@tournament.GolfCourse</p> }
                        @if (!string.IsNullOrWhiteSpace(tournament.Location)) { <p class="field-note" style="margin:0 0 0.5rem;">@tournament.Location</p> }
                        <dl class="details-list" style="margin:0.5rem 0;">
                            <dt>Format</dt><dd>@tournament.Format</dd>
                            <dt>Entry Fee</dt><dd>@tournament.EntryFee.ToString("C")</dd>
                        </dl>
                        <a class="btn" href="~/Tournaments/Details/@tournament.Id?associationId=@assoc.Id">Details &amp; Register</a>
                    </article>
                }
            </div>
        }
    </section>

    @* ── About & Contact ──────────────────────────────────────────── *@
    <section class="section-panel">
        <h2>About @assoc.Name</h2>
        <dl class="details-list">
            @if (!string.IsNullOrWhiteSpace(assoc.ContactEmail))
            {
                <dt>Email</dt><dd>@assoc.ContactEmail</dd>
            }
            @if (!string.IsNullOrWhiteSpace(assoc.ContactPhone))
            {
                <dt>Phone</dt><dd>@assoc.ContactPhone</dd>
            }
            @if (!string.IsNullOrWhiteSpace(assoc.Website))
            {
                <dt>Website</dt>
                <dd><a href="@assoc.Website" target="_blank" rel="noopener noreferrer">@assoc.Website</a></dd>
            }
            @{
                var fullAddr = string.Join(", ", new[] { assoc.Street, assoc.City, assoc.State, assoc.ZipCode, assoc.Country }.Where(v => !string.IsNullOrWhiteSpace(v)));
            }
            @if (!string.IsNullOrWhiteSpace(fullAddr))
            {
                <dt>Address</dt><dd>@fullAddr</dd>
            }
        </dl>
        <a href="~/" class="btn btn-secondary">Back to associations</a>
    </section>
}

