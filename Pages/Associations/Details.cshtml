@page "{id:int}"
@model GolfAssociationCommunity.Pages.Associations.DetailsModel
@{
    ViewData["Title"] = Model.Association?.Name ?? "Association Details";
}
<section class="section-panel">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="message success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="message error">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Association == null)
    {
        <h1>Association not found</h1>
        <p>The association you requested does not exist or is not active.</p>
        <a href="~/" class="btn btn-secondary">Back to associations</a>
    }
    else
    {
        <div class="association-header">
            <div>
                <h1>@Model.Association.Name</h1>
                <p>@Model.Association.Description</p>
                <dl class="details-list">
                    <dt>Location</dt>
                    <dd>@(string.Join(", ", new[] { Model.Association.City, Model.Association.State, Model.Association.Country }.Where(v => !string.IsNullOrWhiteSpace(v))))</dd>
                    <dt>Address</dt>
                    <dd>@(string.Join(", ", new[] { Model.Association.Street, Model.Association.City, Model.Association.State, Model.Association.ZipCode, Model.Association.Country }.Where(v => !string.IsNullOrWhiteSpace(v))))</dd>
                    <dt>Contact Email</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Association.ContactEmail) ? "Not provided" : Model.Association.ContactEmail)</dd>
                    <dt>Contact Phone</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Association.ContactPhone) ? "Not provided" : Model.Association.ContactPhone)</dd>
                    <dt>Website</dt>
                    <dd>
                        @if (string.IsNullOrWhiteSpace(Model.Association.Website))
                        {
                            <span>Not provided</span>
                        }
                        else
                        {
                            <a href="@Model.Association.Website" target="_blank" rel="noopener noreferrer">@Model.Association.Website</a>
                        }
                    </dd>
                    <dt>Total Tournaments</dt>
                    <dd>@Model.Association.Tournaments.Count</dd>
                    <dt>Upcoming Tournaments</dt>
                    <dd>@Model.Association.Tournaments.Count(t => t.StartDate >= DateTime.UtcNow)</dd>
                </dl>
            </div>
        </div>

        @if (Model.ActiveSponsorshipPackages.Count > 0)
        {
            <div class="section-panel">
                <h2>Sponsorship Packages</h2>
                <div class="card-grid">
                    @foreach (var package in Model.ActiveSponsorshipPackages)
                    {
                        <article class="card">
                            <h3>@package.Name</h3>
                            <p>@(string.IsNullOrWhiteSpace(package.Description) ? "Support this association as a sponsor." : package.Description)</p>
                            <div class="card-meta">
                                <span>Level Contribution: @package.Amount.ToString("C")</span>
                            </div>
                            <p>@package.Benefits</p>
                            <a class="btn" href="~/Associations/Sponsor/@Model.Association.Id?selectedPackageId=@package.Id">Sponsor this package</a>
                        </article>
                    }
                </div>
            </div>
        }

        @if (Model.Association.OfficersAndMembers.Any(o => o.IsActive))
        {
            <div class="section-panel">
                <h2>Officers &amp; Members</h2>
                <div class="card-grid">
                    @foreach (var officer in Model.Association.OfficersAndMembers.Where(o => o.IsActive).OrderBy(o => o.DisplayOrder).ThenBy(o => o.Name))
                    {
                        <article class="card">
                            @if (!string.IsNullOrWhiteSpace(officer.PictureUrl))
                            {
                                <img src="@officer.PictureUrl" alt="@officer.Name"
                                     style="width:100%;max-height:180px;object-fit:cover;border-radius:6px;margin-bottom:.75rem;" />
                            }
                            <h3>@officer.Name</h3>
                            <div class="card-meta"><span>@officer.Role</span></div>
                            @if (!string.IsNullOrWhiteSpace(officer.Bio))
                            {
                                <p>@officer.Bio</p>
                            }
                        </article>
                    }
                </div>
            </div>
        }

        @if (Model.RecentLeaderboards.Count > 0)
        {
            <div class="section-panel">
                <h2>Recent Tournament Leaderboards</h2>
                @foreach (var lb in Model.RecentLeaderboards)
                {
                    <div class="section-panel">
                        <h3>@lb.TournamentName</h3>
                        <p class="field-note">@lb.TournamentDates</p>
                        <div class="table-scroll">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Player</th>
                                        <th>Score</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in lb.TopEntries)
                                    {
                                        <tr>
                                            <td>@entry.Position</td>
                                            <td>@(entry.AssociationPlayer?.DisplayName ?? "Unknown")</td>
                                            <td>@entry.TotalScore</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <a class="btn btn-secondary" href="~/Associations/Leaderboard/@Model.Association.Id?TournamentId=@lb.TournamentId">Full results</a>
                    </div>
                }
            </div>
        }

        <div class="section-panel">
            <h2>Tournaments</h2>
            @if (Model.Association.Tournaments == null || Model.Association.Tournaments.Count == 0)
            {
                <p>No tournaments are currently associated with this association.</p>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var tournament in Model.Association.Tournaments.OrderBy(t => t.StartDate))
                    {
                        <article class="card">
                            <h3>@tournament.Name</h3>
                            <p>@tournament.Description</p>
                            <dl class="details-list">
                                <dt>Dates</dt>
                                <dd>@tournament.StartDate.ToString("MMM d, yyyy") - @tournament.EndDate.ToString("MMM d, yyyy")</dd>
                                <dt>Registration Deadline</dt>
                                <dd>@(tournament.RegistrationDeadline.HasValue ? tournament.RegistrationDeadline.Value.ToString("MMM d, yyyy") : "Not set")</dd>
                                <dt>Format</dt>
                                <dd>@tournament.Format</dd>
                                <dt>Location</dt>
                                <dd>@(string.IsNullOrWhiteSpace(tournament.Location) ? "TBD" : tournament.Location)</dd>
                                <dt>Golf Course</dt>
                                <dd>@(string.IsNullOrWhiteSpace(tournament.GolfCourse) ? "TBD" : tournament.GolfCourse)</dd>
                                <dt>Entry Fee</dt>
                                <dd>@tournament.EntryFee.ToString("C")</dd>
                                <dt>Max Players</dt>
                                <dd>@tournament.MaxPlayers</dd>
                                <dt>Status</dt>
                                <dd>@tournament.Status</dd>
                            </dl>
                            <a class="btn" href="~/Tournaments/Details/@tournament.Id?associationId=@Model.Association.Id">Register</a>
                        </article>
                    }
                </div>
            }
        </div>

        <div class="form-actions">
            <a href="~/Associations/Leaderboard/@Model.Association.Id" class="btn">View Leaderboard</a>
            <a href="~/" class="btn btn-secondary">Back to associations</a>
        </div>
    }
</section>

