@page
@model GolfAssociationCommunity.Pages.AssociationAdmin.IndexModel
@{
    ViewData["Title"] = "Association Dashboard";
}

<div class="hero">
    <div class="hero-copy">
        <h1>@ViewData["AssociationName"]</h1>
        <p>Your dedicated association administration portal.</p>
    </div>
</div>

<section class="section-panel">
    <h2>Portal Snapshot</h2>
    <div class="card-grid">
        <article class="card">
            <h3>@Model.TournamentCount</h3>
            <p>Total Tournaments</p>
        </article>
        <article class="card">
            <h3>@Model.UpcomingTournamentCount</h3>
            <p>Upcoming Tournaments</p>
        </article>
        <article class="card">
            <h3>@Model.RegistrationCount</h3>
            <p>Registrations</p>
        </article>
        <article class="card">
            <h3>@Model.PlayerCount</h3>
            <p>Players</p>
        </article>
        <article class="card">
            <h3>@Model.ScoreCount</h3>
            <p>Scores Recorded</p>
        </article>
        <article class="card">
            <h3>@Model.SponsorshipPackageCount</h3>
            <p>Sponsorship Packages</p>
        </article>
        <article class="card">
            <h3>@Model.TransactionCount</h3>
            <p>Payment Transactions</p>
            <a class="card-link" href="~/AssociationAdmin/Transactions">Review transactions</a>
        </article>
    </div>
</section>

<section class="section-panel">
    <h2>Quick Actions</h2>
    <a class="btn" href="~/AssociationAdmin/Players">Manage Players</a>
    <a class="btn" href="~/AssociationAdmin/Tournaments">Manage Tournaments</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/Scores">Manage Scores</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/Leaderboards">View Leaderboards</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/Transactions">Review Transactions</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/Sponsorships">Manage Sponsorships</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/Branding">Manage Branding &amp; Payments</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/CsvImport">&#8679; CSV Import</a>
    <a class="btn btn-secondary" href="~/AssociationAdmin/TournamentData">&#128465; Tournament Data</a>
</section>
