@page
@model GolfAssociationCommunity.Pages.AssociationAdmin.IndexModel
@{
    ViewData["Title"] = "Association Dashboard";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>@ViewData["AssociationName"]</h1>
            <p>Association Administration Portal</p>
        </div>
    </div>
    <h2>Portal Snapshot</h2>
    <div class="card-grid">
        <article class="card">
            <h3>@Model.TournamentCount</h3>
            <p>Total Tournaments</p>
        </article>
        <article class="card">
            <h3>@Model.UpcomingTournamentCount</h3>
            <p>Upcoming Tournaments</p>
        </article>
        <article class="card">
            <h3>@Model.RegistrationCount</h3>
            <p>Registrations</p>
        </article>
        <article class="card">
            <h3>@Model.PlayerCount</h3>
            <p>Players</p>
        </article>
        <article class="card">
            <h3>@Model.ScoreCount</h3>
            <p>Scores Recorded</p>
        </article>
        <article class="card">
            <h3>@Model.SponsorshipPackageCount</h3>
            <p>Sponsorship Packages</p>
        </article>
        <article class="card">
            <h3>@Model.TransactionCount</h3>
            <p>Payment Transactions</p>
            <a class="card-link" href="~/AssociationAdmin/Transactions">Review transactions</a>
        </article>
    </div>
</section>

<section class="section-panel">
    <h2>Quick Actions</h2>
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.75rem;">
        <a class="btn" href="~/AssociationAdmin/Players" title="View and manage association players">Players</a>
        <a class="btn" href="~/AssociationAdmin/Tournaments" title="Create and manage tournaments">Tournaments</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Registrations" title="Manage player registrations">Registrations</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Scores" title="Enter and edit player scores">Scores</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Leaderboards" title="View season standings and tournament leaderboards">Leaderboards</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Transactions" title="Review payment transactions">Transactions</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Members" title="Manage officers and members listed on your public page">Officers &amp; Members</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Sponsorships" title="Manage sponsorship packages">Sponsorships</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Branding" title="Set theme and payment gateway settings">Branding &amp; Payments</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Homepage" title="Edit your public homepage content">Homepage Content</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/CsvImport" title="Bulk-import data from CSV files">&#8679; CSV Import</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/TournamentData" title="Mass-delete tournament data">&#128465; Tournament Data</a>
    </div>
</section>
