@page "{id:int}"
@using GolfAssociationCommunity.Models
@model GolfAssociationCommunity.Pages.AssociationAdmin.EditTournamentModel
@{
    ViewData["Title"] = "Edit Tournament";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Edit Tournament</h1>
            <p>Update tournament details and settings.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn btn-secondary" href="~/AssociationAdmin/Tournaments">&#8592; Back to Tournaments</a>
        </div>
    </div>
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="message success">@success</div>
    }
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="message error"></div>

        <div class="card-grid">
            <div>
                <label asp-for="Input.Name"></label>
                <input asp-for="Input.Name" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.Format"></label>
                <select asp-for="Input.Format" asp-items="Html.GetEnumSelectList<TournamentFormat>()" class="form-control"></select>
            </div>
            <div>
                <label asp-for="Input.StartDate"></label>
                <input asp-for="Input.StartDate" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.EndDate"></label>
                <input asp-for="Input.EndDate" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.RegistrationDeadline"></label>
                <input asp-for="Input.RegistrationDeadline" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.Location"></label>
                <input asp-for="Input.Location" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.GolfCourse"></label>
                <input asp-for="Input.GolfCourse" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.EntryFee"></label>
                <input asp-for="Input.EntryFee" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.HasPracticeRound">Practice Round</label>
                <div style="display:flex;align-items:center;gap:.5rem;margin-top:.4rem;">
                    <input asp-for="Input.HasPracticeRound" id="hasPracticeRoundEdit" />
                    <span class="field-note">Offer a practice round option</span>
                </div>
            </div>
            <div id="practiceRoundFeeEdit" style="display:@(Model.Input.HasPracticeRound ? "block" : "none");">
                <label asp-for="Input.PracticeRoundFee">Practice Round Fee</label>
                <input asp-for="Input.PracticeRoundFee" class="form-control" inputmode="decimal" />
                <span asp-validation-for="Input.PracticeRoundFee" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.MaxPlayers"></label>
                <input asp-for="Input.MaxPlayers" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.Status"></label>
                <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<TournamentStatus>()" class="form-control"></select>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Save Changes</button>
            <a class="btn btn-secondary" href="~/AssociationAdmin/Tournaments">Cancel</a>
        </div>
    </form>
</section>

<section class="section-panel">
    <h2>Flights</h2>
    <p class="field-note">Define flights to group players in the leaderboard. Players must select a flight when registering. Leave empty to run this tournament without flights.</p>

    @if (TempData["ErrorMessage"] is string err)
    {
        <div class="message error">@err</div>
    }

    @if (Model.Flights.Count > 0)
    {
        <div class="table-scroll" style="margin-bottom:1.5rem;">
            <table class="table">
                <thead>
                    <tr><th>Order</th><th>Name</th><th>Description</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var flight in Model.Flights)
                {
                    <tr>
                        <td>
                            <form method="post" asp-page-handler="UpdateFlightOrder" asp-route-id="@Model.TournamentId" asp-route-flightId="@flight.Id" class="inline-form" style="display:flex;gap:0.35rem;align-items:center;">
                                <input type="number" name="displayOrder" value="@flight.DisplayOrder" class="form-control" style="width:5rem;" aria-label="Display order for @flight.Name" />
                                <button type="submit" class="link-button">Save</button>
                            </form>
                        </td>
                        <td>@flight.Name</td>
                        <td>@(flight.Description ?? "—")</td>
                        <td>
                            <form method="post" asp-page-handler="DeleteFlight" asp-route-id="@Model.TournamentId" asp-route-flightId="@flight.Id"
                                  class="inline-form" onsubmit="return confirm('Remove flight \'@flight.Name\'?');">
                                <button type="submit" class="link-button">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="margin-bottom:1rem;">No flights defined yet.</p>
    }

    <form method="post" asp-page-handler="AddFlight" asp-route-id="@Model.TournamentId" class="form-shell">
        <h3 class="form-section-title">Add Flight</h3>
        <div class="form-grid">
            <div>
                <label asp-for="NewFlight.Name">Flight Name</label>
                <input asp-for="NewFlight.Name" class="form-control" placeholder="e.g. A, B, Championship, Senior" />
                <span asp-validation-for="NewFlight.Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="NewFlight.Description">Description <span class="field-note">(optional)</span></label>
                <input asp-for="NewFlight.Description" class="form-control" placeholder="e.g. Handicap 0–12" />
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn">Add Flight</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('hasPracticeRoundEdit').addEventListener('change', function () {
            document.getElementById('practiceRoundFeeEdit').style.display = this.checked ? 'block' : 'none';
        });
    </script>
}
}
