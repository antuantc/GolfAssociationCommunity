@page
@model GolfAssociationCommunity.Pages.AssociationAdmin.PlayersModel
@{
    ViewData["Title"] = "Association Players";
}

<section class="section-panel">
    <div class="page-header-row">
        <h1>Association Players</h1>
        @if (Model.Players.Count > 0)
        {
            <span class="badge">@Model.Players.Count active</span>
        }
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="message success">@success</div>
    }

    <details class="collapsible-form" @(Model.IsEditing ? "open" : "")>
        <summary class="collapsible-form__toggle">
            <span>@(Model.IsEditing ? "Edit Player" : "Add Player")</span>
        </summary>
        <form method="post" asp-page-handler="Save" enctype="multipart/form-data" class="form-shell" style="margin-top:1rem;">
            <div class="form-section">
                <div asp-validation-summary="ModelOnly" class="message error"></div>
                <input type="hidden" asp-for="EditId" />
                <div class="form-grid">
                    <div>
                        <label asp-for="Input.DisplayName"></label>
                        <input asp-for="Input.DisplayName" class="form-control" />
                        <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Input.Email"></label>
                        <input asp-for="Input.Email" class="form-control" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Input.HandicapIndex">Handicap</label>
                        <input asp-for="Input.HandicapIndex" type="number" step="0.1" class="form-control" />
                        <span asp-validation-for="Input.HandicapIndex" class="text-danger"></span>
                    </div>
                    <div>
                        <label for="Photo">Player Photo</label>
                        @if (!string.IsNullOrWhiteSpace(Model.Input.ExistingPhotoUrl))
                        {
                            <div style="margin-bottom:0.5rem;">
                                <img src="@Model.Input.ExistingPhotoUrl" alt="Current photo" class="player-photo-thumb" />
                            </div>
                            <form method="post" asp-page-handler="DeletePhoto" asp-route-id="@Model.EditId" class="inline-form" style="margin-bottom:0.4rem;">
                                <button type="submit" class="link-button danger" onclick="return confirm('Remove this photo?')">Remove photo</button>
                            </form>
                        }
                        <input id="Photo" name="Photo" type="file" accept="image/*" class="form-control" />
                        <input type="hidden" asp-for="Input.ExistingPhotoUrl" />
                        <small class="form-text">JPG, PNG, GIF or WebP. Max 5 MB.</small>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn">@(Model.IsEditing ? "Save Player" : "Add Player")</button>
                    @if (Model.IsEditing)
                    {
                        <a class="btn btn-secondary" href="~/AssociationAdmin/Players">Cancel</a>
                    }
                </div>
            </div>
        </form>
    </details>

    @if (Model.Players.Count == 0)
    {
        <p style="margin-top:1rem;">No players are currently assigned to this association.</p>
    }
    else
    {
        <div class="players-section-header">
            <h2 id="active-players">Active Players</h2>
            <span id="player-search-count" class="table-toolbar__count"></span>
            <a href="?handler=DownloadCsv" class="btn btn-secondary btn-sm" style="margin-left:auto;">&#8595; Download CSV</a>
        </div>

        <form id="bulk-assoc-player-delete" method="post" asp-page-handler="DeleteSelected"></form>
        <div class="table-toolbar table-toolbar--sticky">
            <label class="table-toolbar__select-all">
                <input type="checkbox" id="select-all-assoc-players" title="Select all" />
                Select all
            </label>
            <button type="submit" form="bulk-assoc-player-delete" class="btn btn-danger btn-sm"
                    onclick="return document.querySelectorAll('.assoc-player-check:checked').length > 0 || (alert('Select at least one player.'), false)">
                Delete Selected
            </button>
            <span id="assoc-player-selected-count" class="table-toolbar__count"></span>
            <span id="player-search-count" class="table-toolbar__count"></span>
        </div>
        <div class="table-scroll">
            <table class="table" id="players-table">
                <thead>
                    <tr>
                        <th class="col-check"></th>
                        <th>Player</th>
                        <th>Email</th>
                        <th>Handicap</th>
                        <th>Tournaments</th>
                        <th>Scores</th>
                        <th>Wins</th>
                        <th>Last Activity</th>
                    </tr>
                    <tr>
                        <th></th>
                        <th><input type="search" id="col-filter-name" class="form-control" placeholder="Filter name&hellip;" autocomplete="off" oninput="filterAssocPlayers()" style="font-weight:normal;min-width:120px;" /></th>
                        <th><input type="search" id="col-filter-email" class="form-control" placeholder="Filter email&hellip;" autocomplete="off" oninput="filterAssocPlayers()" style="font-weight:normal;min-width:150px;" /></th>
                        <th colspan="5"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var player in Model.Players)
                {
                    <tr id="player-@player.Id" data-name="@player.DisplayName.ToLower()" data-email="@player.Email.ToLower()">
                        <td class="col-check"><input type="checkbox" class="assoc-player-check" name="Ids" value="@player.Id" form="bulk-assoc-player-delete" /></td>
                        <td>
                            <div class="player-name-cell">
                                @if (!string.IsNullOrWhiteSpace(player.PhotoUrl))
                                {
                                    <img src="@player.PhotoUrl" alt="" class="player-photo-thumb" />
                                }
                                else
                                {
                                    <span class="player-avatar-initials">@(player.DisplayName.Length > 0 ? player.DisplayName[0].ToString().ToUpper() : "?")</span>
                                }
                                <div>
                                    <div>@player.DisplayName</div>
                                    <div class="row-actions" style="margin-top:0.3rem;">
                                        <a class="btn btn-secondary btn-xs" href="~/AssociationAdmin/Players?EditId=@player.Id">Edit</a>
                                        <a class="btn btn-secondary btn-xs" href="~/AssociationAdmin/Scores?AssociationPlayerId=@player.Id">Scores</a>
                                        <form method="post" asp-page-handler="Archive" asp-route-id="@player.Id" class="inline-form"
                                              onsubmit="return confirm('Archive this player? They will be moved to the Archived Players section and hidden from active rosters.');">                                            <button type="submit" class="btn btn-secondary btn-xs">Archive</button>
                                        </form>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@player.Id" class="inline-form"
                                              onsubmit="return confirm('Delete this player from this association? This will remove linked score history.');">
                                            <button type="submit" class="btn btn-danger btn-xs">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted-sm">@player.Email</td>
                        <td>@(player.HandicapIndex.HasValue ? player.HandicapIndex.Value.ToString("0.0#") : "-")</td>
                        <td class="num-cell">@player.TournamentCount</td>
                        <td class="num-cell">@player.ScoreCount</td>
                        <td class="num-cell">@player.Wins</td>
                        <td class="text-muted-sm">@(player.LastScoreUpdateUtc.HasValue ? player.LastScoreUpdateUtc.Value.ToString("MMM d, yyyy") : "-")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <p id="no-results-msg" class="text-muted" style="display:none;margin-top:0.75rem;">No players match your search.</p>
    }

    <details class="collapsible-form" style="margin-top:1.5rem;">
        <summary class="collapsible-form__toggle">
            <span>Archived Players@(Model.ArchivedPlayers.Count > 0 ? $" ({Model.ArchivedPlayers.Count})" : "")</span>
        </summary>
        @if (Model.ArchivedPlayers.Count == 0)
        {
            <p style="margin-top:0.75rem;">No archived players for this association.</p>
        }
        else
        {
            <div class="table-scroll" style="margin-top:0.75rem;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Player</th>
                            <th>Email</th>
                            <th>Handicap</th>
                            <th>Tournaments</th>
                            <th>Scores</th>
                            <th>Wins</th>
                            <th>Last Activity</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var player in Model.ArchivedPlayers)
                    {
                        <tr>
                            <td>
                                <div class="player-name-cell">
                                    @if (!string.IsNullOrWhiteSpace(player.PhotoUrl))
                                    {
                                        <img src="@player.PhotoUrl" alt="" class="player-photo-thumb" />
                                    }
                                    else
                                    {
                                        <span class="player-avatar-initials">@(player.DisplayName.Length > 0 ? player.DisplayName[0].ToString().ToUpper() : "?")</span>
                                    }
                                    <div>
                                        <div>@player.DisplayName</div>
                                        <div style="margin-top:0.3rem;">
                                            <form method="post" asp-page-handler="Activate" asp-route-id="@player.Id" class="inline-form">
                                                <button type="submit" class="btn btn-secondary btn-xs">Reactivate</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted-sm">@player.Email</td>
                            <td>@(player.HandicapIndex.HasValue ? player.HandicapIndex.Value.ToString("0.0#") : "-")</td>
                            <td class="num-cell">@player.TournamentCount</td>
                            <td class="num-cell">@player.ScoreCount</td>
                            <td class="num-cell">@player.Wins</td>
                            <td class="text-muted-sm">@(player.LastScoreUpdateUtc.HasValue ? player.LastScoreUpdateUtc.Value.ToString("MMM d, yyyy") : "-")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </details>
</section>

<script>
function filterAssocPlayers() {
    var qName  = (document.getElementById('col-filter-name')?.value  || '').trim().toLowerCase();
    var qEmail = (document.getElementById('col-filter-email')?.value || '').trim().toLowerCase();
    var anyFilter = qName || qEmail;
    var rows = document.querySelectorAll('#players-table tbody tr');
    var visible = 0;
    rows.forEach(function(row) {
        var name  = (row.dataset.name  || '');
        var email = (row.dataset.email || '');
        var match = (!qName  || name.indexOf(qName)   >= 0) &&
                    (!qEmail || email.indexOf(qEmail)  >= 0);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
        if (!match) {
            var cb = row.querySelector('.assoc-player-check');
            if (cb) cb.checked = false;
        }
    });
    var searchInfo = document.getElementById('player-search-count');
    var noResults  = document.getElementById('no-results-msg');
    if (searchInfo) searchInfo.textContent = anyFilter ? visible + ' result' + (visible !== 1 ? 's' : '') : '';
    if (noResults) noResults.style.display = (anyFilter && visible === 0) ? '' : 'none';
    var selectAll = document.getElementById('select-all-assoc-players');
    var countEl   = document.getElementById('assoc-player-selected-count');
    if (countEl || selectAll) {
        var checked = document.querySelectorAll('.assoc-player-check:checked').length;
        var total   = document.querySelectorAll('.assoc-player-check').length;
        if (countEl) countEl.textContent = checked > 0 ? checked + ' of ' + total + ' selected' : '';
        if (selectAll) { selectAll.indeterminate = checked > 0 && checked < total; selectAll.checked = total > 0 && checked === total; }
    }
}

var _assocSelectAll = document.getElementById('select-all-assoc-players');
if (_assocSelectAll) {
    _assocSelectAll.addEventListener('change', function() {
        var isChecked = this.checked;
        document.querySelectorAll('#players-table tbody tr:not([style*="display: none"]) .assoc-player-check').forEach(function(cb) { cb.checked = isChecked; });
        filterAssocPlayers();
    });
}
document.querySelectorAll('.assoc-player-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
        filterAssocPlayers();
    });
});

['col-filter-name','col-filter-email'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', filterAssocPlayers);
});
