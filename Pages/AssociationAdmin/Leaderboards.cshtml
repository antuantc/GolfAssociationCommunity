@page
@model GolfAssociationCommunity.Pages.AssociationAdmin.LeaderboardsModel
@{
    ViewData["Title"] = "Leaderboards";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Leaderboards</h1>
            <p>Season standings and tournament-level results for this association.</p>
        </div>
        <div class="admin-page-header__actions">
            <form method="post" asp-page-handler="RecalculateAssociation" class="inline-form">
                <button type="submit" class="btn btn-secondary" title="Recalculate leaderboard entries from current score data">&#8635; Recalculate All</button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="message success">@success</div>
    }

    <form method="get">
        <div class="admin-filter-bar">
            <div>
                <label for="tournamentId">Tournament Leaderboard</label>
                <select id="tournamentId" name="TournamentId" class="form-control" onchange="this.form.submit()">
                    <option value="">Select a tournament</option>
                    @foreach (var tournament in Model.Tournaments)
                    {
                        <option value="@tournament.Id" selected="@(Model.TournamentId == tournament.Id)">@tournament.Name</option>
                    }
                </select>
            </div>
        </div>
    </form>
</section>

<section class="section-panel">
    <h2>Association Season Standings</h2>
    <p>Ranked by season points (earned per tournament within each player&rsquo;s flight), then most wins, then average finish position.</p>

    <details style="margin-bottom:1rem;">
        <summary style="cursor:pointer;font-size:0.88rem;font-weight:600;color:var(--brand-accent);user-select:none;">How are points calculated? &#9660;</summary>
        <div style="margin-top:0.6rem;padding:0.85rem 1rem;background:#f8fafd;border:1px solid var(--card-border);border-radius:0.45rem;font-size:0.88rem;line-height:1.6;">
            <p style="margin:0 0 0.5rem;">Each tournament awards points by <strong>finish position within the player&rsquo;s flight</strong> (or overall if no flights are used):</p>
            <p style="margin:0 0 0.3rem;">1st = 25 pts &bull; 2nd = 24 pts &bull; 3rd = 23 pts &bull; &hellip; &bull; 25th+ = 1 pt (minimum)</p>
            <p style="margin:0;">Points accumulate across all tournaments. <strong>Players who switch flights between events are not penalized</strong> &mdash; each tournament is ranked independently within its flights. Tiebreakers: most wins &rarr; best average finish &rarr; lowest average score.</p>
        </div>
    </details>

    @if (Model.AssociationLeaderboard.Count == 0)
    {
        <p>No leaderboard data is available yet. Record scores for registered players to populate rankings.</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Position</th>
                        <th title="Total season points — primary ranking criterion">Points</th>
                        <th>Player</th>
                        <th>Email</th>
                        <th>Played</th>
                        <th>Wins</th>
                        <th>Avg Finish</th>
                        <th>Avg Score</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.AssociationLeaderboard)
                {
                    <tr>
                        <td>@row.OverallPosition</td>
                        <td><strong>@row.TournamentPoints</strong></td>
                        <td>@row.PlayerName</td>
                        <td>@row.PlayerEmail</td>
                        <td>@row.TournamentsPlayed</td>
                        <td>@row.Wins</td>
                        <td>@row.AveragePosition.ToString("0.##")</td>
                        <td>@row.AverageScore.ToString("0.##")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@if (Model.SelectedTournament != null)
{
    <section class="section-panel">
        <div class="form-actions">
            <div>
                <h2>@Model.SelectedTournament.Name Leaderboard</h2>
                <p>@Model.SelectedTournament.StartDate.ToString("MMM d, yyyy") - @Model.SelectedTournament.EndDate.ToString("MMM d, yyyy")</p>
            </div>
            <form method="post" asp-page-handler="RecalculateTournament" asp-route-tournamentId="@Model.SelectedTournament.Id">
                <button type="submit" class="btn btn-secondary">Recalculate This Tournament</button>
            </form>
        </div>

        @if (Model.TournamentLeaderboard.Count == 0)
        {
            <p>No leaderboard entries are available for this tournament yet.</p>
        }
        else if (Model.HasMultipleFlights)
        {
            @foreach (var flight in Model.TournamentFlights)
            {
                var flightRows = Model.TournamentLeaderboard.Where(r => (r.Flight ?? string.Empty) == flight).ToList();
                <h3 style="margin-top:1.5rem;">@(string.IsNullOrEmpty(flight) ? "No Flight Assigned" : $"Flight {flight}")</h3>
                <div class="table-scroll">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Position</th>
                                <th>Player</th>
                                <th>Score</th>
                                @if (Model.HasTiebreakerData)
                                {
                                    <th title="Scores on hardest handicap holes used as tiebreakers">Hdcp Hole Scores (TB)</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in flightRows)
                        {
                            <tr>
                                <td>@row.Position</td>
                                <td>
                                    @(row.AssociationPlayer?.DisplayName ?? "Unknown Player")
                                    @if (!string.IsNullOrWhiteSpace(row.Flight))
                                    {
                                        <small class="pill" style="margin-left:0.35rem;font-size:0.72rem;">@row.Flight</small>
                                    }
                                </td>
                                <td>@row.TotalScore</td>
                                @if (Model.HasTiebreakerData)
                                {
                                    var tbScores = Model.TiebreakersByPlayer.TryGetValue(row.AssociationPlayerId, out var s) ? string.Join(", ", s) : "—";
                                    <td>@tbScores</td>
                                }
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <div class="table-scroll">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Position</th>
                            <th>Player</th>
                            <th>Score</th>
                            @if (Model.HasTiebreakerData)
                            {
                                <th title="Scores on hardest handicap holes used as tiebreakers">Hdcp Hole Scores (TB)</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.TournamentLeaderboard)
                    {
                        <tr>
                            <td>@row.Position</td>
                            <td>
                                @(row.AssociationPlayer?.DisplayName ?? "Unknown Player")
                                @if (!string.IsNullOrWhiteSpace(row.Flight))
                                {
                                    <small class="pill" style="margin-left:0.35rem;font-size:0.72rem;">@row.Flight</small>
                                }
                            </td>
                            <td>@row.TotalScore</td>
                            @if (Model.HasTiebreakerData)
                            {
                                var tbScores = Model.TiebreakersByPlayer.TryGetValue(row.AssociationPlayerId, out var s) ? string.Join(", ", s) : "—";
                                <td>@tbScores</td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

<section class="section-panel">
    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/AssociationAdmin">&#8592; Back to Dashboard</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Tournaments">Tournaments</a>
    </div>
</section>
