@page
@using GolfAssociationCommunity.Models
@model GolfAssociationCommunity.Pages.AssociationAdmin.CreateTournamentModel
@{
    ViewData["Title"] = "Create Tournament";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Create Tournament</h1>
            <p>Set up a new tournament for your association.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn btn-secondary" href="~/AssociationAdmin/Tournaments">&#8592; Back to Tournaments</a>
        </div>
    </div>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="message error"></div>

        <div class="card-grid">
            <div>
                <label asp-for="Input.Name"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.Format"></label>
                <select asp-for="Input.Format" asp-items="Html.GetEnumSelectList<TournamentFormat>()" class="form-control"></select>
            </div>
            <div>
                <label asp-for="Input.StartDate"></label>
                <input asp-for="Input.StartDate" class="form-control" />
                <span asp-validation-for="Input.StartDate" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.EndDate"></label>
                <input asp-for="Input.EndDate" class="form-control" />
                <span asp-validation-for="Input.EndDate" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.RegistrationDeadline"></label>
                <input asp-for="Input.RegistrationDeadline" class="form-control" />
                <span asp-validation-for="Input.RegistrationDeadline" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.Location"></label>
                <input asp-for="Input.Location" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.GolfCourse"></label>
                <input asp-for="Input.GolfCourse" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.EntryFee"></label>
                <input asp-for="Input.EntryFee" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.HasPracticeRound">Practice Round</label>
                <div style="display:flex;align-items:center;gap:.5rem;margin-top:.4rem;">
                    <input asp-for="Input.HasPracticeRound" id="hasPracticeRoundCreate" />
                    <span class="field-note">Offer a practice round option</span>
                </div>
            </div>
            <div id="practiceRoundFeeCreate" style="display:@(Model.Input.HasPracticeRound ? "block" : "none");">
                <label asp-for="Input.PracticeRoundFee">Practice Round Fee</label>
                <input asp-for="Input.PracticeRoundFee" class="form-control" inputmode="decimal" />
                <span asp-validation-for="Input.PracticeRoundFee" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.MaxPlayers"></label>
                <input asp-for="Input.MaxPlayers" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.Status"></label>
                <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<TournamentStatus>()" class="form-control"></select>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Create Tournament</button>
            <a class="btn btn-secondary" href="~/AssociationAdmin/Tournaments">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('hasPracticeRoundCreate').addEventListener('change', function () {
            document.getElementById('practiceRoundFeeCreate').style.display = this.checked ? 'block' : 'none';
        });
    </script>
}
