@page
@using GolfAssociationCommunity.Models
@model GolfAssociationCommunity.Pages.AssociationAdmin.ScoresModel
@{
    ViewData["Title"] = "Tournament Scores";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Score Management</h1>
            <p>Select a tournament and player to enter or update round scores.</p>
        </div>
    </div>
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="message success">@success</div>
    }

    <form method="get" class="form-shell">
        <div class="form-section">
            <h2 class="form-section-title">Select Tournament and Player</h2>
            <div class="form-grid">
                <div>
                    <label asp-for="TournamentId">Tournament</label>
                    <select asp-for="TournamentId" class="form-control" onchange="this.form.submit()">
                        <option value="">Select tournament</option>
                        @foreach (var tournament in Model.Tournaments)
                        {
                            <option value="@tournament.Id">@tournament.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label asp-for="AssociationPlayerId">Player</label>
                    @if (Model.TournamentId.HasValue)
                    {
                            <select asp-for="AssociationPlayerId" class="form-control">
                            <option value="">Select player</option>
                            @foreach (var player in Model.Players)
                            {
                                <option value="@player.Id">@player.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                            <select asp-for="AssociationPlayerId" class="form-control" disabled>
                            <option value="">Select player</option>
                        </select>
                    }
                </div>
                <div>
                    <label asp-for="Round">Round</label>
                    <input asp-for="Round" type="number" min="1" class="form-control" />
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn">Load Scorecard</button>
            </div>
        </div>
    </form>
</section>

@if (Model.SelectedTournament != null && Model.AssociationPlayerId.HasValue)
{
    <section class="section-panel">
        <div class="form-meta">
            <span class="pill">Tournament: @Model.SelectedTournament.Name</span>
            <span class="pill">Player: @Model.SelectedPlayerName</span>
            <span class="pill">Round: @Model.Round</span>
            <span class="pill">Total Score: @Model.CurrentTotalScore</span>
            @if (!string.IsNullOrWhiteSpace(Model.SelectedFlight))
            {
                <span class="pill">Flight: @Model.SelectedFlight</span>
            }
        </div>

        <form method="post" asp-page-handler="Save" class="form-shell">
            <input type="hidden" asp-for="TournamentId" />
            <input type="hidden" asp-for="AssociationPlayerId" />
            <input type="hidden" asp-for="Round" />
            <div asp-validation-summary="ModelOnly" class="message error"></div>

            <div class="form-section">
                <h3 class="form-section-title">Flight <span class="field-note">(optional — groups players in leaderboard)</span></h3>
                <div class="form-grid" style="grid-template-columns:1fr 2fr;max-width:500px;">
                    <div>
                        <label asp-for="FlightInput">Flight</label>
                        @if (Model.TournamentFlights.Count > 0)
                        {
                            <select asp-for="FlightInput" class="form-control">
                                <option value="">— No flight —</option>
                                @foreach (var f in Model.TournamentFlights)
                                {
                                    <option value="@f.Name">@f.Name@(string.IsNullOrWhiteSpace(f.Description) ? "" : $" — {f.Description}")</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input asp-for="FlightInput" class="form-control" placeholder="e.g. A, B, Championship" maxlength="50" />
                            <span class="field-note">Leave blank if this tournament uses no flights.</span>
                        }
                    </div>
                </div>
            </div>

            <div class="form-section">
                <p class="field-note">Enter one total per round. If totals tie, the scores on the hardest handicap holes are used as sequential tiebreakers.</p>
                <div class="form-grid">
                    <div>
                        <label asp-for="Input.TotalScore">Round Score</label>
                        <input asp-for="Input.TotalScore" type="number" min="1" class="form-control" />
                        <span asp-validation-for="Input.TotalScore" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title">Tiebreaker Hole Scores <span class="field-note">(optional &mdash; enter score on each hole ranked by difficulty)</span></h3>
                <div class="form-grid">
                    @for (int i = 0; i < PlayerScore.MaxTiebreakerEntries; i++)
                    {
                        string label = i switch { 0 => "Hole Handicap #1 (Hardest)", 1 => "Hole Handicap #2", 2 => "Hole Handicap #3", _ => "Hole Handicap #4" };
                        <div>
                            <label>@label</label>
                            <input asp-for="Input.Tiebreakers[i].Score" type="number" min="1" max="15" class="form-control" />
                        </div>
                    }
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn">Save Scores and Recalculate Leaderboard</button>
                <a class="btn btn-secondary" href="~/AssociationAdmin/Leaderboards?TournamentId=@Model.TournamentId">View Leaderboard</a>
            </div>
        </form>
    </section>
}
else if (Model.TournamentId.HasValue)
{
    <section class="section-panel">
        <p>Select a registered player to load and manage the scorecard.</p>
        <form method="post" asp-page-handler="DeleteTournamentScores" class="inline-form"
              onsubmit="return confirm('Delete ALL scores for this tournament and recalculate the leaderboard? This cannot be undone.');">
            <input type="hidden" name="TournamentId" value="@Model.TournamentId" />
            <button type="submit" class="btn btn-danger">Delete All Scores for This Tournament</button>
        </form>
    </section>
}

<section class="section-panel">
    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/AssociationAdmin">&#8592; Back to Dashboard</a>
        <a class="btn btn-secondary" href="~/AssociationAdmin/Tournaments">Tournaments</a>
    </div>
</section>
