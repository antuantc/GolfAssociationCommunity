@page
@using GolfAssociationCommunity.Models
@model GolfAssociationCommunity.Pages.AssociationAdmin.TournamentsModel
@{
    ViewData["Title"] = "Manage Tournaments";
}

<section class="section-panel">
    <div class="admin-page-header">
        <div>
            <h1>Tournaments</h1>
            <p>Create and manage association tournaments.</p>
        </div>
        <div class="admin-page-header__actions">
            <a class="btn" href="~/AssociationAdmin/CreateTournament" title="Create a new tournament">+ Create Tournament</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="message success">@success</div>
    }

    @if (Model.Tournaments.Count == 0)
    {
        <p>No tournaments created yet. Use <strong>+ Create Tournament</strong> above to get started.</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Actions</th>
                        <th>Name</th>
                        <th>Dates</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var tournament in Model.Tournaments)
                {
                    var statusBadge = tournament.Status switch {
                        TournamentStatus.Scheduled => "status-badge status-badge--blue",
                        TournamentStatus.Ongoing   => "status-badge status-badge--green",
                        TournamentStatus.Completed => "status-badge status-badge--gray",
                        TournamentStatus.Cancelled => "status-badge status-badge--red",
                        _ => "status-badge status-badge--gray"
                    };
                    <tr>
                        <td>
                            <div style="display:flex;gap:0.35rem;flex-wrap:wrap;">
                                <a class="btn btn-secondary btn-xs" href="~/AssociationAdmin/EditTournament/@tournament.Id" title="Edit tournament details">Edit</a>
                                <a class="btn btn-secondary btn-xs" href="~/AssociationAdmin/Registrations?TournamentId=@tournament.Id" title="View registrations for this tournament">Registrations</a>
                                <a class="btn btn-secondary btn-xs" href="~/AssociationAdmin/Scores?TournamentId=@tournament.Id" title="Enter scores for this tournament">Scores</a>
                                <a class="btn btn-secondary btn-xs" href="~/AssociationAdmin/Leaderboards?TournamentId=@tournament.Id" title="View leaderboard for this tournament">Leaderboard</a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@tournament.Id" class="inline-form" onsubmit="return confirm('Delete @tournament.Name? This cannot be undone.')">
                                    <button type="submit" class="btn btn-danger btn-xs" title="Permanently delete this tournament">Delete</button>
                                </form>
                            </div>
                        </td>
                        <td><strong>@tournament.Name</strong></td>
                        <td class="text-muted-sm">@tournament.StartDate.ToString("MMM d, yyyy") &ndash; @tournament.EndDate.ToString("MMM d, yyyy")</td>
                        <td><span class="@statusBadge">@tournament.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="admin-back-nav">
        <a class="btn btn-secondary" href="~/AssociationAdmin">&#8592; Back to Dashboard</a>
    </div>
</section>
