@page
@model GolfAssociationCommunity.Pages.MyRegistrationsModel
@{
    ViewData["Title"] = "My Registrations";
}
<section class="section-panel">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="message success">@TempData["SuccessMessage"]</div>
    }

    <h1>My Tournament Registrations</h1>

    @if (Model.Registrations.Count == 0)
    {
        <p>You have not registered for any tournaments yet.</p>
        <a class="btn" href="~/Tournaments">Browse tournaments</a>
    }
    else
    {
        <div class="card-grid">
            @foreach (var registration in Model.Registrations)
            {
                <article class="card">
                    <h2>@registration.Tournament?.Name</h2>
                    <p>Status: <strong>@registration.Status</strong></p>
                    <p>Registered on @registration.RegistrationDate.ToString("MMM d, yyyy")</p>
                    <div class="card-meta">
                        <span>Entry fee: @registration.RegistrationFee:C</span>
                        <span>Payment: @(registration.PaymentConfirmed ? "Confirmed" : "Pending")</span>
                    </div>
                    <a class="card-link" href="~/Tournaments/Details/@registration.TournamentId">View tournament</a>
                    @if (registration.Status == GolfAssociationCommunity.Models.RegistrationStatus.Registered)
                    {
                        <form method="post" asp-page-handler="Withdraw" class="inline-form">
                            <input type="hidden" name="registrationId" value="@registration.Id" />
                            <input type="hidden" name="reason" value="User requested withdrawal" />
                            <button type="submit" class="btn btn-secondary">Withdraw</button>
                        </form>
                    }
                </article>
            }
        </div>
    }
</section>
