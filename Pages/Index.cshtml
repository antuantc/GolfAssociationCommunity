@page
@model IndexModel
@{
    ViewData["Title"] = "Golf Association Community";
}

<div class="hero hero--video">
    <video class="hero-video-bg" autoplay muted loop playsinline>
        <source src="/videos/golf-bg.mp4" type="video/mp4" />
    </video>
    <div class="hero-video-overlay"></div>
    <div class="hero-copy">
        <h1>Golf Association Community</h1>
        <p>Your hub for competitive golf. Browse associations, view tournament schedules, check standings, and register to play.</p>
    </div>
</div>

@* Stats rollup across all associations *@
@if (Model.TotalAssociations > 0)
{
    <div class="hub-stats-bar">
        <div class="hub-stat">
            <span class="hub-stat__num">@Model.TotalAssociations</span>
            <span class="hub-stat__label">ASSOCIATIONS</span>
        </div>
        <div class="hub-stat">
            <span class="hub-stat__num">@Model.TotalTournaments+</span>
            <span class="hub-stat__label">TOURNAMENTS</span>
        </div>
        <div class="hub-stat">
            <span class="hub-stat__num">@Model.GlobalLeaderboard.Count+</span>
            <span class="hub-stat__label">PLAYERS RANKED</span>
        </div>
    </div>
}

<section class="section-panel">
    <h2>Active Golf Associations</h2>
    @if (Model.AssociationStats.Count == 0)
    {
        <p>No active associations are available right now.</p>
    }
    else
    {
        <div class="hub-assoc-grid">
            @foreach (var stat in Model.AssociationStats)
            {
                var a = stat.Association;
                var loc = string.Join(", ", new[] { a.City, a.State }.Where(s => !string.IsNullOrWhiteSpace(s)));
                <article class="hub-assoc-card" style="--card-accent: var(--brand-accent);">
                    <div class="hub-assoc-card__img @(!string.IsNullOrWhiteSpace(a.HeroImageUrl) ? "" : "hub-assoc-card__img--gradient")"
                         @(!string.IsNullOrWhiteSpace(a.HeroImageUrl) ? Html.Raw($"style=\"background-image:url('{a.HeroImageUrl}')\"") : Html.Raw(""))>
                        @if (!string.IsNullOrWhiteSpace(a.LogoUrl))
                        {
                            <img src="@a.LogoUrl" class="hub-assoc-card__logo" alt="@a.Name" />
                        }
                    </div>
                    <div class="hub-assoc-card__body">
                        @if (a.EstYear.HasValue && a.EstYear.Value > 1800)
                        {
                            <p class="hub-assoc-card__est">EST. @a.EstYear</p>
                        }
                        <h3 class="hub-assoc-card__name">@a.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(loc)) { <p class="hub-assoc-card__loc">@loc</p> }
                        @if (!string.IsNullOrWhiteSpace(a.Description)) { <p class="hub-assoc-card__desc">@a.Description</p> }
                        <div class="hub-assoc-card__counts">
                            <span>@stat.TournamentCount Tournaments</span>
                            @if (stat.UpcomingCount > 0) { <span class="hub-badge-upcoming">@stat.UpcomingCount Upcoming</span> }
                        </div>
                        @if (stat.NextTournament != null)
                        {
                            <p class="hub-assoc-card__next">
                                <strong>Next:</strong> @stat.NextTournament.Name &mdash; @stat.NextTournament.StartDate.ToString("MMM d, yyyy")
                            </p>
                        }
                        <a class="hub-assoc-card__cta" href="~/Associations/Details/@a.Id">VIEW ASSOCIATION &rarr;</a>
                    </div>
                </article>
            }
        </div>
    }
</section>

@if (Model.GlobalLeaderboard.Count > 0)
{
    <section class="section-panel">
        <div style="display:flex;align-items:baseline;gap:1rem;flex-wrap:wrap;margin-bottom:0.5rem;">
            <h2 style="margin:0;">Top Players</h2>
            <span style="font-size:0.8rem;color:var(--muted-text);">All associations &mdash; 25 pts for a flight win, down to 1 pt &mdash; min. 2 tournaments played</span>
        </div>
        <details style="margin-bottom:0.9rem;">
            <summary style="cursor:pointer;font-size:0.82rem;font-weight:600;color:var(--brand-accent);user-select:none;">How are points calculated? &#9660;</summary>
            <div style="margin-top:0.5rem;padding:0.75rem 0.9rem;background:#f8fafd;border:1px solid var(--card-border);border-radius:0.45rem;font-size:0.85rem;line-height:1.6;">
                <p style="margin:0 0 0.35rem;">Points are awarded by <strong>finish position within your flight</strong> in each tournament:</p>
                <p style="margin:0 0 0.35rem;">1st = 25 pts &bull; 2nd = 24 pts &bull; 3rd = 23 pts &bull; &hellip; &bull; 25th+ = 1 pt minimum</p>
                <p style="margin:0;">Season totals accumulate across all associations. Switching flights between events doesn&rsquo;t affect your standing &mdash; each tournament is scored independently. Tiebreakers: most wins &rarr; best average finish. Minimum 2 tournaments to appear here.</p>
            </div>
        </details>
        <div class="hub-lb-grid">
            @foreach (var row in Model.GlobalLeaderboard)
            {
                var pts = row.PlayerName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                var ini = string.Join("", pts.Take(2).Select(s => s[0].ToString().ToUpperInvariant()));
                var medalClass = row.OverallPosition == 1 ? "hub-lb-card--gold" : row.OverallPosition == 2 ? "hub-lb-card--silver" : row.OverallPosition == 3 ? "hub-lb-card--bronze" : "";
                <div class="hub-lb-card @medalClass">
                    <span class="hub-lb-card__pos">@row.OverallPosition</span>
                    <span class="hub-lb-avatar">@ini</span>
                    <div class="hub-lb-card__info">
                        <p class="hub-lb-card__name">@row.PlayerName</p>
                        <p class="hub-lb-card__stats"><strong>@row.TournamentPoints pts</strong> &bull; @row.TournamentsPlayed T &bull; @row.Wins W</p>
                    </div>
                </div>
            }
        </div>
    </section>
}

