@page
@model IndexModel
@{
    ViewData["Title"] = "Choose an Association";
}
<div class="hero">
    <div class="hero-copy">
        <h1>Choose an Association</h1>
        <p>Select a golf association to enter its public site, browse only its tournaments, and register as a player.</p>
    </div>
</div>
<section class="section-panel">
    <h2>Active Golf Associations</h2>
    @if (Model.Associations.Count == 0)
    {
        <p>No active associations are available right now.</p>
    }
    else
    {
        <div class="card-grid">
            @foreach (var association in Model.Associations)
            {
                <article class="card">
                    <h3>@association.Name</h3>
                    <p>@association.Description</p>
                    <div class="card-meta">
                        <span>@association.City, @association.State</span>
                    </div>
                    <a class="card-link" href="~/Associations/Details/@association.Id">View details</a>
                </article>
            }
        </div>
    }
</section>

@if (Model.GlobalLeaderboard.Count > 0)
{
    <section class="section-panel">
        <h2>Top Players &mdash; All Associations</h2>
        <p class="field-note">Ranked by tournament finish points accumulated across all associations and tournaments.</p>
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Email</th>
                        <th>Tournaments</th>
                        <th>Wins</th>
                        <th>Avg Finish</th>
                        <th>Total Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.GlobalLeaderboard)
                    {
                        <tr>
                            <td>@row.OverallPosition</td>
                            <td>@row.PlayerName</td>
                            <td>@row.PlayerEmail</td>
                            <td>@row.TournamentsPlayed</td>
                            <td>@row.Wins</td>
                            <td>@row.AveragePosition.ToString("0.##")</td>
                            <td>@row.TotalScore</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}
