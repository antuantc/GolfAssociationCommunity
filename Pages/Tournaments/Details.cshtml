@page "{id:int}"
@model GolfAssociationCommunity.Pages.Tournaments.DetailsModel
@{
    ViewData["Title"] = Model.Tournament?.Name ?? "Tournament Details";
}
<div class="pub-inner-page">
<div class="pub-container">
<div class="section-panel">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="message success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="message error">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Tournament == null)
    {
        <h1>Tournament not found</h1>
        <p>The tournament you requested does not exist.</p>
        @if (Model.AssociationId.HasValue)
        {
            <a class="btn btn-secondary" href="~/Associations/Tournaments?associationId=@Model.AssociationId">Back to association tournaments</a>
        }
        else
        {
            <a class="btn btn-secondary" href="~/Tournaments">Browse tournaments</a>
        }
    }
    else
    {
        <div class="association-header">
            <h1>@Model.Tournament.Name</h1>
            <p>@Model.Tournament.Description</p>
            <div class="details-list">
                <dt>Association</dt>
                <dd>@Model.Tournament.GolfAssociation?.Name</dd>
                <dt>Dates</dt>
                <dd>@Model.Tournament.StartDate.ToString("MMM d, yyyy") - @Model.Tournament.EndDate.ToString("MMM d, yyyy")</dd>
                <dt>Format</dt>
                <dd>@Model.Tournament.Format</dd>
                <dt>Location</dt>
                <dd>@Model.Tournament.Location</dd>
                <dt>Entry Fee</dt>
                <dd>@Model.Tournament.EntryFee.ToString("C")</dd>
                <dt>Registration</dt>
                <dd>@Model.RegistrationCount / @Model.Tournament.MaxPlayers registered</dd>
                <dt>Status</dt>
                <dd>@Model.Tournament.Status</dd>
            </div>
        </div>

        <div class="section-panel">
            <h2>Registration</h2>
            @if (Model.CanRegister)
            {
                <form method="post" asp-page-handler="Register" autocomplete="on">
                    <input type="hidden" name="tournamentId" value="@Model.Tournament.Id" />
                    <input type="hidden" name="associationId" value="@Model.AssociationId" />
                    <div asp-validation-summary="ModelOnly" class="message error"></div>

                    <div class="form-shell">
                        <div class="form-section">
                            <h3 class="form-section-title">Registration Details</h3>
                            <div class="form-meta">
                                <span class="pill">Entry Fee: @Model.Tournament.EntryFee.ToString("C")</span>
                                @if (Model.Tournament.HasPracticeRound)
                                {
                                    <span class="pill">Practice Round: @Model.Tournament.PracticeRoundFee.ToString("C")</span>
                                }
                                <span class="pill">Spots: @Model.RegistrationCount / @Model.Tournament.MaxPlayers</span>
                            </div>

                            <div class="form-grid">
                                <div>
                            <label asp-for="Input.GuestName">Full Name</label>
                            <input asp-for="Input.GuestName" class="form-control" autocomplete="name" />
                            <span asp-validation-for="Input.GuestName" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.GuestEmail">Email</label>
                            <input asp-for="Input.GuestEmail" class="form-control" autocomplete="email" />
                            <span asp-validation-for="Input.GuestEmail" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.Handicap">Handicap</label>
                            <input asp-for="Input.Handicap" type="number" step="0.1" class="form-control" inputmode="decimal" placeholder="e.g. 12.4" />
                            <span asp-validation-for="Input.Handicap" class="text-danger"></span>
                                    <div class="field-note">Required. Use your most recent verified handicap.</div>
                                </div>
                                @if (Model.TournamentFlights.Count > 0)
                                {
                                    <div>
                                        <label asp-for="Input.FlightId">Flight <span class="field-note">(required)</span></label>
                                        <select asp-for="Input.FlightId" class="form-control">
                                            <option value="">— Select your flight —</option>
                                            @foreach (var f in Model.TournamentFlights)
                                            {
                                                <option value="@f.Id">@f.Name@(string.IsNullOrWhiteSpace(f.Description) ? "" : $" — {f.Description}")</option>
                                            }
                                        </select>
                                        <span asp-validation-for="Input.FlightId" class="text-danger"></span>
                                    </div>
                                }
                                @if (Model.Tournament.HasPracticeRound)
                                {
                                    <div class="full">
                                        <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer;">
                                            <input asp-for="Input.IncludePracticeRound" id="includePracticeRound" style="width:auto;" />
                                            <span>Add Practice Round — <strong>@Model.Tournament.PracticeRoundFee.ToString("C")</strong></span>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title">Payment Details</h3>
                            <div class="security-note">Card details are sent directly for authorization and are not stored in full.</div>

                            <div class="form-grid">
                                <div class="full">
                            <label asp-for="Input.CardholderName">Cardholder Name</label>
                            <input asp-for="Input.CardholderName" class="form-control" autocomplete="cc-name" />
                            <span asp-validation-for="Input.CardholderName" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.CardNumber">Card Number <span class="card-type-badge" id="regCardTypeBadge" style="display:none;"></span></label>
                            <input asp-for="Input.CardNumber" class="form-control" inputmode="numeric" autocomplete="cc-number" placeholder="0000 0000 0000 0000" />
                            <span asp-validation-for="Input.CardNumber" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.CardExpiry">Expiry (MM/YY)</label>
                            <input asp-for="Input.CardExpiry" class="form-control" inputmode="numeric" autocomplete="cc-exp" placeholder="MM/YY" />
                            <span asp-validation-for="Input.CardExpiry" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.Cvv">CVV</label>
                            <input asp-for="Input.Cvv" type="password" class="form-control" inputmode="numeric" autocomplete="cc-csc" maxlength="4" />
                            <span asp-validation-for="Input.Cvv" class="text-danger"></span>
                                </div>
                                <div class="full">
                            <label asp-for="Input.BillingAddressLine1">Billing Address</label>
                            <input asp-for="Input.BillingAddressLine1" class="form-control" autocomplete="billing address-line1" />
                            <span asp-validation-for="Input.BillingAddressLine1" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.BillingCity">City</label>
                            <input asp-for="Input.BillingCity" class="form-control" autocomplete="billing address-level2" />
                            <span asp-validation-for="Input.BillingCity" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.BillingState">State/Province</label>
                            <input asp-for="Input.BillingState" class="form-control" autocomplete="billing address-level1" />
                            <span asp-validation-for="Input.BillingState" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.BillingZipCode">Postal Code</label>
                            <input asp-for="Input.BillingZipCode" class="form-control" autocomplete="billing postal-code" />
                            <span asp-validation-for="Input.BillingZipCode" class="text-danger"></span>
                                </div>
                                <div>
                            <label asp-for="Input.BillingCountry">Country</label>
                            <input asp-for="Input.BillingCountry" class="form-control" autocomplete="billing country" />
                            <span asp-validation-for="Input.BillingCountry" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="checkout-summary">
                            <div class="checkout-summary__title">Order Summary</div>
                            <div class="checkout-summary__row">
                                <span>Tournament Entry</span>
                                <span>@Model.Tournament.EntryFee.ToString("C")</span>
                            </div>
                            @if (Model.Tournament.HasPracticeRound)
                            {
                                <div class="checkout-summary__row" id="summaryPracticeRow" style="display:none;">
                                    <span>Practice Round</span>
                                    <span>@Model.Tournament.PracticeRoundFee.ToString("C")</span>
                                </div>
                            }
                            <div class="checkout-summary__total">
                                <span>Total Due</span>
                                <strong id="summaryTotal">@Model.Tournament.EntryFee.ToString("C")</strong>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn" id="regSubmitBtn">
                                <span id="regSubmitLabel">Pay <span id="regTotalDisplay">@Model.Tournament.EntryFee.ToString("C")</span></span>
                                <span class="btn-spinner" id="regSpinner" style="display:none;"></span>
                            </button>
                        </div>
                    </div>
                </form>
                @if (Model.Tournament.HasPracticeRound)
                {
                    <script>
                        (function () {
                            var entryFee = @Model.Tournament.EntryFee;
                            var practiceRoundFee = @Model.Tournament.PracticeRoundFee;
                            var cb = document.getElementById('includePracticeRound');
                            function syncTotal() {
                                var hasPractice = cb && cb.checked;
                                var total = entryFee + (hasPractice ? practiceRoundFee : 0);
                                var fmt = '$' + total.toFixed(2);
                                var el = document.getElementById('summaryTotal');
                                var el2 = document.getElementById('regTotalDisplay');
                                var row = document.getElementById('summaryPracticeRow');
                                if (el) el.textContent = fmt;
                                if (el2) el2.textContent = fmt;
                                if (row) row.style.display = hasPractice ? '' : 'none';
                            }
                            if (cb) cb.addEventListener('change', syncTotal);
                        })();
                    </script>
                }
            }
            else
            {
                <p>Registration is not available for this tournament.</p>
            }
        </div>

        @if (Model.Leaderboard.Any())
        {
            var tdFlights = Model.TournamentFlights.Select(f => f.Name)
                .Where(name => Model.Leaderboard.Any(r => (r.Flight ?? "") == name))
                .Concat(Model.Leaderboard.Select(r => r.Flight ?? "").Distinct()
                    .Where(f => !Model.TournamentFlights.Any(tf => tf.Name == f)).OrderBy(f => f))
                .ToList();
            var tdMultiFlights = tdFlights.Count > 1 || (tdFlights.Count == 1 && tdFlights[0] != "");
            <div class="section-panel">
                <h2>Results</h2>
                <div class="pub-filter-bar">
                    <input type="search" placeholder="&#128269; Search player..." oninput="filterTdLb(this)" style="min-width:200px;" />
                    <a class="btn btn-secondary" href="~/Associations/Leaderboard/@Model.Tournament?.GolfAssociationId?TournamentId=@Model.Tournament?.Id">Full standings</a>
                </div>
                @foreach (var flight in tdFlights)
                {
                    var fRows = Model.Leaderboard.Where(r => (r.Flight ?? "") == flight).ToList();
                    if (tdMultiFlights)
                    {
                        <p class="pub-flight-heading">@(string.IsNullOrEmpty(flight) ? "All Players" : $"Flight {flight}")</p>
                    }
                    <div class="table-scroll">
                        <table class="table sortable-table" data-td-flight="@flight">
                            <thead>
                                <tr>
                                    <th data-sort="num" data-col="0">#</th>
                                    <th data-sort="str" data-col="1">Player</th>
                                    <th data-sort="num" data-col="2">Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in fRows)
                                {
                                    <tr>
                                        <td>@entry.Position</td>
                                        <td>@(entry.AssociationPlayer?.DisplayName ?? "Unknown")</td>
                                        <td>@entry.TotalScore</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        @if (Model.AssociationId.HasValue)
        {
            <a class="btn btn-secondary" href="~/Associations/Tournaments?associationId=@Model.AssociationId">Back to association tournaments</a>
        }
        else
        {
            <a class="btn btn-secondary" href="~/Tournaments">Back to tournaments</a>
        }
    }
</div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function filterTdLb(input) {
        var term = input.value.toLowerCase();
        document.querySelectorAll('.sortable-table[data-td-flight] tbody tr').forEach(function(row) {
            row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
        });
    }
    document.querySelectorAll('.sortable-table').forEach(function(table) {
        table.querySelectorAll('th[data-sort]').forEach(function(th) {
            th.addEventListener('click', function() {
                var col = parseInt(th.dataset.col), type = th.dataset.sort;
                var asc = !th.classList.contains('sort-asc');
                table.querySelectorAll('th').forEach(function(h) { h.classList.remove('sort-asc','sort-desc'); });
                th.classList.add(asc ? 'sort-asc' : 'sort-desc');
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                rows.sort(function(a,b) {
                    var av = a.cells[col] ? a.cells[col].textContent.trim() : '';
                    var bv = b.cells[col] ? b.cells[col].textContent.trim() : '';
                    return asc ? (type==='num' ? (parseFloat(av)||0)-(parseFloat(bv)||0) : av.localeCompare(bv))
                               : (type==='num' ? (parseFloat(bv)||0)-(parseFloat(av)||0) : bv.localeCompare(av));
                });
                rows.forEach(function(r) { tbody.appendChild(r); });
            });
        });
    });
    </script>
    <script>
        (function () {
            var cardNumberInput = document.getElementById('Input_CardNumber');
            var cardExpiryInput = document.getElementById('Input_CardExpiry');
            var cardTypeBadge = document.getElementById('regCardTypeBadge');

            function detectCardType(d) {
                if (/^4/.test(d)) return 'Visa';
                if (/^5[1-5]|^2[2-7]/.test(d)) return 'Mastercard';
                if (/^3[47]/.test(d)) return 'Amex';
                if (/^6(?:011|5)/.test(d)) return 'Discover';
                return '';
            }

            if (cardNumberInput) {
                cardNumberInput.addEventListener('input', function (e) {
                    var digits = e.target.value.replace(/\D/g, '').slice(0, 16);
                    e.target.value = digits.replace(/(.{4})/g, '$1 ').trim();
                    if (cardTypeBadge) {
                        var type = detectCardType(digits);
                        cardTypeBadge.textContent = type;
                        cardTypeBadge.style.display = type ? '' : 'none';
                    }
                });
            }

            if (cardExpiryInput) {
                cardExpiryInput.addEventListener('input', function (e) {
                    var digits = e.target.value.replace(/\D/g, '').slice(0, 4);
                    e.target.value = digits.length > 2 ? digits.slice(0, 2) + '/' + digits.slice(2) : digits;
                });
            }

            var regSubmitBtn = document.getElementById('regSubmitBtn');
            if (regSubmitBtn) {
                regSubmitBtn.closest('form').addEventListener('submit', function () {
                    regSubmitBtn.disabled = true;
                    var spinner = document.getElementById('regSpinner');
                    var label = document.getElementById('regSubmitLabel');
                    if (spinner) spinner.style.display = 'inline-block';
                    if (label) label.textContent = 'Processing\u2026';
                });
            }
        })();
    </script>
}
