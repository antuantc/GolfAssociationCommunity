@{
    ViewContext.RouteData.Values.TryGetValue("page", out var currentPageValue);
    var currentPage = currentPageValue?.ToString() ?? string.Empty;

    string ActiveClass(string page)
    {
        return string.Equals(currentPage, page, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;
    }
}

<ul class="nav nav-pills flex-column">
    <li class="nav-item">
        <a class="nav-link @ActiveClass("/Account/Manage/Index")" id="profile" href="/Identity/Account/Manage">Profile</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @ActiveClass("/Account/Manage/Email")" id="email" href="/Identity/Account/Manage/Email">Email</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @ActiveClass("/Account/Manage/ChangePassword")" id="change-password" href="/Identity/Account/Manage/ChangePassword">Password</a>
    </li>
</ul>
